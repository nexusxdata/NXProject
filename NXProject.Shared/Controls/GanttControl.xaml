<UserControl x:Class="NXProject.Controls.GanttControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho de datas (altura sincronizada com o header do DataGrid) -->
        <Canvas x:Name="HeaderCanvas" Grid.Row="0" Background="#E8E8E8" ClipToBounds="True"/>

        <!-- Overlay de coordenada: flutua no topo do cabeçalho sobre o texto do mês -->
        <Border x:Name="DateCoordBorder"
                Grid.Row="0"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                Background="#DD1A2A3A"
                CornerRadius="3"
                Padding="6,2"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="0,2,0,0"
                Panel.ZIndex="10">
            <TextBlock x:Name="DateCoordLabel"
                       FontSize="10" Foreground="White" FontWeight="SemiBold"/>
        </Border>

        <!-- Scroll horizontal compartilhado; vertical sincronizado com o DataGrid -->
        <ScrollViewer Grid.Row="1" x:Name="GanttScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      ScrollChanged="OnScrollChanged">
            <Canvas x:Name="GanttCanvas"
                    Background="Transparent"
                    ClipToBounds="True"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    MouseDown="OnCanvasMouseDown"
                    MouseMove="OnCanvasMouseMove"
                    MouseUp="OnCanvasMouseUp"
                    MouseLeave="OnCanvasMouseLeave"
                    MouseRightButtonDown="OnCanvasRightMouseDown"
                    MouseRightButtonUp="OnCanvasRightMouseUp"
                    ToolTipOpening="OnGanttCanvasToolTipOpening"/>
        </ScrollViewer>

        <Grid x:Name="MagnifierOverlay"
              Grid.Row="1"
              Width="168"
              Height="168"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              IsHitTestVisible="False"
              Visibility="Collapsed"
              Panel.ZIndex="20">
            <Ellipse Stroke="#F59E0B"
                     StrokeThickness="2"
                     SnapsToDevicePixels="True">
                <Ellipse.Fill>
                    <VisualBrush x:Name="MagnifierBrush"
                                 Visual="{Binding ElementName=GanttCanvas}"
                                 ViewboxUnits="Absolute"
                                 Stretch="Fill"/>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Stroke="#FFFFFFFF"
                     StrokeThickness="1"
                     Margin="3"
                     Opacity="0.75"/>
        </Grid>

    </Grid>
</UserControl>
