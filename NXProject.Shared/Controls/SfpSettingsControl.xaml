<UserControl x:Class="NXProject.Controls.SfpSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="SPF"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Configure em separado os parametros usados para converter faixas de Simple Function Point em duracao estimada das atividades."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MaxWidth="620"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Baixa ate 3 SPF"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding LowDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem ate 3 SPF."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Media maior que 3 e menor que 6"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding MediumDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem mais de 3 e menos de 6 SPF."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Alta maior ou igual a 6"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding HighDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem 6 SPF ou mais."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="16"
                    Background="#F6F8FB"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MaxWidth="620"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="O que e SPF?"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap">
                        <Run Text="SPF significa "/>
                        <Run Text="Simple Function Point" FontWeight="SemiBold"/>
                        <Run Text=". E uma forma de medir o tamanho funcional do software a partir das funcionalidades entregues ao usuario, ajudando na estimativa de esforco e duracao."/>
                    </TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Faixas usadas no sistema: "/>
                        <Run Text="Baixa ate 3 SPF" FontWeight="SemiBold"/>
                        <Run Text=", "/>
                        <Run Text="Media maior que 3 e menor que 6" FontWeight="SemiBold"/>
                        <Run Text=" e "/>
                        <Run Text="Alta maior ou igual a 6" FontWeight="SemiBold"/>
                        <Run Text="."/>
                    </TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}"
                               TextWrapping="Wrap">
                        <Hyperlink NavigateUri="https://handwiki.org/wiki/The_Simple_Function_Point_%28SFP%29_method"
                                   RequestNavigate="OnRequestNavigate">
                            Ver conceito de SPF na web
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
