<UserControl x:Class="NXProject.Controls.TaskGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

    <DataGrid x:Name="TaskGrid"
              ItemsSource="{Binding Tasks, RelativeSource={RelativeSource AncestorType=UserControl}}"
              SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
              AutoGenerateColumns="False"
              AllowDrop="True"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              ScrollViewer.CanContentScroll="False"
              SelectionUnit="FullRow"
              Background="White"
              BorderThickness="0"
              RowHeight="22"
              ColumnHeaderHeight="40"
              PreviewMouseMove="OnTaskGridPreviewMouseMove"
              DragOver="OnTaskGridDragOver"
              Drop="OnTaskGridDrop"
              BeginningEdit="OnTaskGridBeginningEdit"
              CellEditEnding="OnTaskGridCellEditEnding"
              SelectionChanged="OnTaskGridSelectionChanged">

        <DataGrid.Resources>
            <!-- Seleção inativa (grid sem foco): laranja em vez do cinza padrão -->
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                             Color="#E07B20"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                             Color="White"/>
        </DataGrid.Resources>

        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{Binding HierarchyBackground}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsHighlightedPredecessor}" Value="True">
                        <Setter Property="Background" Value="#FFEEDD"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasSyncConflict}" Value="True">
                        <Setter Property="Background" Value="#FFDDDD"/>
                        <Setter Property="Foreground" Value="#A4262C"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DataGrid.RowStyle>

        <DataGrid.CellStyle>
            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </DataGrid.CellStyle>

        <DataGrid.Columns>

            <!-- ID (clicável: abre edição do vínculo DevOps) -->
            <DataGridTemplateColumn x:Name="IdColumn" Header="ID" Width="55" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayId}"
                                PreviewMouseLeftButtonDown="OnIdCellPreviewMouseLeftButtonDown"
                                Click="OnIdCellClick"
                                ToolTip="{DynamicResource Tooltip_IdCell}"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=Foreground}"
                                FontSize="11"
                                Padding="0"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Margin="3,0"
                                               TextAlignment="Left"
                                               VerticalAlignment="Center"
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Tipo + Estado DevOps (compacto: ex. "FEA·A") -->
            <DataGridTemplateColumn x:Name="DevOpsColumn" Header="T·E" Width="50" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DevOpsTag}"
                                   Foreground="{Binding DevOpsBrush}"
                                   ToolTip="{Binding DevOpsTooltip}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Nome (com indentação) -->
            <DataGridTemplateColumn x:Name="NameColumn" Header="{DynamicResource Col_TaskName}" Width="*" MinWidth="120">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Indent}"/>
                                <ColumnDefinition Width="14"/><!-- botão expand -->
                                <ColumnDefinition Width="Auto"/><!-- ícone tipo -->
                                <ColumnDefinition Width="*"/><!-- nome -->
                            </Grid.ColumnDefinitions>

                            <!-- Botão expand/collapse — só visível em tarefas-sumário -->
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                          PreviewMouseLeftButtonDown="OnHierarchyTogglePreviewMouseLeftButtonDown"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Width="14" Height="14"
                                          Padding="0" BorderThickness="0"
                                          Background="Transparent"
                                          Cursor="Hand"
                                          Focusable="False">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <TextBlock x:Name="Arrow"
                                                               Text="▶"
                                                               FontSize="9"
                                                               Foreground="#2B579A"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <!-- Ícone: milestone ou summary -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,3,0"
                                       FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayAsMilestone}" Value="True">
                                                <Setter Property="Text" Value="♦"/>
                                                <Setter Property="Foreground" Value="Goldenrod"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Nome (+ selo BLOCK quando bloqueado) -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- BLOCK de Story (⛔) tem prioridade; se só Task (🔴) mostra Task -->
                                <Border Margin="0,0,5,0" Padding="4,0" CornerRadius="3"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsBlockedByStory, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FDE7E9"/>
                                            <Setter Property="BorderBrush" Value="#D13438"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Retirar Block da Story"
                                                      Click="OnToggleStoryBlockClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <TextBlock Text="⛔ BLOCK" FontSize="9" FontWeight="SemiBold"
                                               Foreground="#A4262C" VerticalAlignment="Center"
                                               ToolTip="Bloqueado (tag Block na Story)"/>
                                </Border>
                                <!-- BLOCK de Task filha — só mostra se Story NÃO tem Block -->
                                <Border Margin="0,0,5,0" Padding="4,0" CornerRadius="3"
                                        Background="#FFF4CE" BorderBrush="#C8A600" BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsBlockedByTask}"  Value="True"/>
                                                        <Condition Binding="{Binding IsBlockedByStory}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="🔴 BLOCK" FontSize="9" FontWeight="SemiBold"
                                               Foreground="#7A5200" VerticalAlignment="Center"
                                               ToolTip="Bloqueado por Task filha"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           ContextMenuOpening="OnNameContextMenuOpening">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{DynamicResource Ctx_AddStoryBlock}" Click="OnToggleStoryBlockClick"/>
                                            <MenuItem x:Name="ToggleTaskBlockMenuItem"
                                                      Header="🔴 Adicionar Block na Task"
                                                      Click="OnToggleTaskBlockClick"
                                                      Visibility="Collapsed"/>
                                            <Separator/>
                                            <MenuItem x:Name="FetchChildTasksMenuItem"
                                                      Header="📋 Grid de Tasks (DevOps)"
                                                      Click="OnFetchChildTasksClick"
                                                      ToolTip="Abre a grid de Tasks desta Story para editar e incluir no cronograma"/>
                                            <MenuItem x:Name="ExpandChildTasksMenuItem"
                                                      Header="📂 Expandir Tasks no cronograma"
                                                      Click="OnExpandChildTasksClick"
                                                      ToolTip="Inclui as Tasks desta Story diretamente no cronograma"/>
                                            <MenuItem x:Name="SuppressChildTasksMenuItem"
                                                      Header="🗑 Suprimir Tasks do cronograma"
                                                      Click="OnSuppressChildTasksClick"
                                                      ToolTip="Remove todas as Tasks filhas desta Story do cronograma (não apaga no DevOps)"/>
                                            <Separator x:Name="AddTaskSeparator" Visibility="Collapsed"/>
                                            <MenuItem x:Name="AddDevOpsTaskMenuItem"
                                                      Header="➕ Nova Task (DevOps)"
                                                      Click="OnAddDevOpsTaskClick"
                                                      Visibility="Collapsed"
                                                      ToolTip="Cria uma nova Task vinculada ao DevOps"/>
                                            <MenuItem x:Name="AddInternalTaskMenuItem"
                                                      Header="📌 Nova Atividade Interna"
                                                      Click="OnAddInternalTaskClick"
                                                      Visibility="Collapsed"
                                                      ToolTip="Cria uma atividade interna sem vínculo com DevOps"/>
                                            <Separator/>
                                            <MenuItem Header="{DynamicResource Ctx_EditDescription}"
                                                      Click="OnEditDescriptionClick"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Indent}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     HorizontalAlignment="Stretch" TextAlignment="Left"/>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Duração -->
            <DataGridTemplateColumn x:Name="DurationColumn" Header="{DynamicResource Col_Duration}" Width="60">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Border Padding="2,0"
                                CornerRadius="2"
                                Background="Transparent"
                                ContextMenuOpening="OnDurationContextMenuOpening">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding OriginalEstimatedHoursText}" IsEnabled="False"
                                              FontStyle="Italic" Foreground="#555"
                                              Visibility="{Binding HasOriginalEstimate, Converter={StaticResource BoolToVis}}"/>
                                    <Separator Visibility="{Binding HasOriginalEstimate, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem x:Name="ToggleGanttOriginalMenuItem"
                                              Click="OnToggleGanttOriginalViewClick"
                                              Visibility="{Binding HasOriginalEstimate, Converter={StaticResource BoolToVis}}"/>
                                    <Separator Visibility="{Binding HasDevOpsLink, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem x:Name="FetchTaskHoursMenuItem"
                                              Header="🔄 Atualizar duração pelas Tasks (DevOps)"
                                              Visibility="{Binding HasDevOpsLink, Converter={StaticResource BoolToVis}}"
                                              Click="OnFetchTaskHoursClick"
                                              ToolTip="Soma os HH Estimados das Tasks filhas no DevOps e atualiza a duração desta atividade"/>
                                    <Separator/>
                                    <MenuItem x:Name="ToggleOrgHMenuItem"
                                              Click="OnToggleOrgHColumnClick"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <TextBlock Text="{Binding DurationHours, StringFormat={}{0:0.#}}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UsesSfpEstimate}" Value="True">
                                                <Setter Property="Foreground" Value="#6E6E6E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesSfpEstimate}" Value="True">
                                            <Setter Property="Background" Value="#F1F1F1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasOriginalEstimate}" Value="True">
                                            <Setter Property="BorderBrush" Value="#B0C4DE"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding DurationHours, StringFormat={}{0:0.#}, Mode=OneTime}"
                                 BorderThickness="0"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="{Binding IsDurationReadOnly}"
                                 GotFocus="OnEditTextBoxGotFocus"
                                 LostFocus="OnDurationEditLostFocus"
                                 KeyDown="OnDurationEditKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                    <Setter Property="IsTabStop" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDurationReadOnly}" Value="True">
                                            <Setter Property="Background" Value="#F1F1F1"/>
                                            <Setter Property="Foreground" Value="#6E6E6E"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                            <Setter Property="IsTabStop" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- SFP -->
            <DataGridTextColumn x:Name="SfpColumn" Header="SFP" Binding="{Binding SfpPoints}" Width="55">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Estimativa Original (OrgH) — visível quando ShowOriginalHoursColumn = true -->
            <DataGridTextColumn x:Name="OriginalHoursColumn" Header="{DynamicResource Col_OrgH}"
                                Binding="{Binding OriginalEstimatedHoursDisplay, Mode=OneWay}"
                                Width="50" IsReadOnly="True"
                                Visibility="Collapsed">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#1565C0"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- HH Atual (oculto por padrão) -->
            <DataGridTextColumn x:Name="RealizedHoursColumn" Header="{DynamicResource Col_HHAtual}"
                                Binding="{Binding CurrentHoursDisplay}" Width="80" IsReadOnly="True"
                                Visibility="Collapsed">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#4A148C"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- HH Restante (oculto por padrão) -->
            <DataGridTextColumn x:Name="EstimatedHoursColumn" Header="{DynamicResource Col_HHRestante}"
                                Binding="{Binding EstimatedHoursDisplay}" Width="80" IsReadOnly="True"
                                Visibility="Collapsed">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#1565C0"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Prioridade (Pri) — visível e editável apenas para Tasks -->
            <DataGridTemplateColumn x:Name="PriorityColumn" Header="Pri" Width="40">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding PriorityDisplay}"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#E07000" FontWeight="SemiBold"
                                   Visibility="{Binding IsDevOpsTask, Converter={StaticResource BoolToVis}}"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding PriorityDisplay, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"
                                 LostFocus="OnPriorityEditLostFocus"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Início -->
            <DataGridTemplateColumn x:Name="StartColumn" Header="{DynamicResource Col_Start}" Width="110" SortMemberPath="Start">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StartDisplay}"
                                   VerticalAlignment="Center"
                                   Margin="3,0"
                                   PreviewMouseLeftButtonDown="OnStartDisplayPreviewMouseLeftButtonDown">
                            <TextBlock.ContextMenu>
                                <ContextMenu Opened="OnStartContextMenuOpened">
                                    <MenuItem Header="{DynamicResource Ctx_FixStartDate}"
                                              Click="OnFixStartClick"/>
                                    <MenuItem Header="{DynamicResource Ctx_ClearFixedDate}"
                                              Command="{Binding ClearStartFixedCommand}"
                                              IsEnabled="{Binding StartFixed}"/>
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <TextBox x:Name="StartEditBox"
                                 Text="{Binding Start, StringFormat=dd/MM/yyyy, UpdateSourceTrigger=Explicit}"
                                 VerticalAlignment="Center"
                                 GotFocus="OnEditTextBoxGotFocus"
                                 PreviewMouseLeftButtonDown="OnStartEditPreviewMouseLeftButtonDown"
                                 KeyDown="OnStartEditKeyDown"
                                 LostFocus="OnStartEditLostFocus"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Fim -->
            <DataGridTemplateColumn x:Name="FinishColumn" Header="{DynamicResource Col_Finish}" Width="110" SortMemberPath="Finish">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FinishDisplay}" VerticalAlignment="Center" Margin="3,0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <TextBox x:Name="FinishEditBox"
                                 Text="{Binding Finish, StringFormat=dd/MM/yyyy, UpdateSourceTrigger=Explicit}"
                                 VerticalAlignment="Center"
                                 GotFocus="OnEditTextBoxGotFocus"
                                 KeyDown="OnFinishEditKeyDown"
                                 LostFocus="OnFinishEditLostFocus"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- % Completo -->
            <DataGridTemplateColumn x:Name="PercentColumn" Header="{DynamicResource Col_PercentComplete}" Width="70">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Grid Margin="2,1">
                            <ProgressBar Value="{Binding PercentComplete}" Maximum="100" Height="12"
                                         Background="#C9D8E8" Foreground="#217346"/>
                            <TextBlock Text="{Binding PercentComplete, StringFormat={}{0:0.#}%}"
                                       HorizontalAlignment="{Binding PercentCompleteTextAlignment}"
                                       Margin="{Binding PercentCompleteTextMargin}"
                                       VerticalAlignment="Center"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{Binding PercentCompleteTextBrush}"/>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding PercentComplete, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.#}}"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 GotFocus="OnEditTextBoxGotFocus">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="IsReadOnly" Value="True"/>
                                    <Setter Property="Background" Value="#F1F1F1"/>
                                    <Setter Property="Foreground" Value="#6E6E6E"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanEditPercentComplete}" Value="True">
                                            <Setter Property="IsReadOnly" Value="False"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="IsHitTestVisible" Value="True"/>
                                            <Setter Property="IsTabStop" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Predecessoras -->
            <DataGridTemplateColumn x:Name="PredecessorColumn" Header="{DynamicResource Col_Predecessors}" Width="80" SortMemberPath="PredecessorsText">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="{Binding PredecessorsText}"
                                Click="OnPredecessorCellClick"
                                ToolTip="{DynamicResource Tooltip_PredClick}"
                                BorderThickness="0"
                                Background="Transparent"
                                Padding="3,0"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Ctx_HighlightPred}" Click="OnHighlightPredecessorsClick"/>
                                    <MenuItem Header="{DynamicResource Ctx_ClearPredHighlight}" Click="OnClearPredecessorHighlightClick"
                                              Visibility="{Binding IsHighlightSource, Converter={StaticResource BoolToVis}}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <Button Content="{Binding PredecessorsText}"
                                Click="OnPredecessorCellClick"
                                ToolTip="{DynamicResource Tooltip_PredClick}"
                                BorderThickness="0"
                                Background="Transparent"
                                Padding="3,0"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Ctx_HighlightPred}" Click="OnHighlightPredecessorsClick"/>
                                    <MenuItem Header="{DynamicResource Ctx_ClearPredHighlight}" Click="OnClearPredecessorHighlightClick"
                                              Visibility="{Binding IsHighlightSource, Converter={StaticResource BoolToVis}}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Recursos (editável: ComboBox com criação rápida) -->
            <DataGridTemplateColumn x:Name="ResourcesColumn" Header="{DynamicResource Col_Resources}" Width="100">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ResourcesText, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Margin="3,0">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Ctx_EditAllocPerc}"
                                              Click="OnEditPercAlocClick"/>
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding AvailableResources, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding PrimaryResource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  IsEditable="True"
                                  StaysOpenOnEdit="False"
                                  IsTextSearchEnabled="False"
                                  DropDownOpened="OnResourceComboDropDownOpened"
                                  DropDownClosed="OnResourceComboDropDownClosed"
                                  KeyDown="OnResourceComboKeyDown"
                                  BorderThickness="0"
                                  Padding="4,2"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Sprint: mostra o NOME da sprint do DevOps; editável via dropdown -->
            <DataGridTemplateColumn x:Name="SprintColumn" Header="Sprint" Width="90">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Border x:Name="SprintBorder" Background="Transparent">
                            <TextBlock x:Name="SprintText"
                                       Text="{Binding SprintDisplay}"
                                       TextAlignment="Left"
                                       Margin="3,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsFinishBeyondSprint}" Value="True">
                                <Setter TargetName="SprintBorder" Property="Background" Value="#FFF3E0"/>
                                <Setter TargetName="SprintBorder" Property="ToolTip" Value="A data fim da atividade ultrapassa o fim da sprint. Considere migrar para outra sprint ou encerrar a atividade."/>
                                <Setter TargetName="SprintText" Property="Foreground" Value="#E65100"/>
                                <Setter TargetName="SprintText" Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate>
                        <ComboBox ItemsSource="{Binding AvailableSprintsForTask}"
                                  SelectedValuePath="Path"
                                  SelectedValue="{Binding SprintPath, Mode=OneWay}"
                                  IsEditable="False"
                                  DropDownOpened="OnSprintComboDropDownOpened"
                                  DropDownClosed="OnSprintComboDropDownClosed">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SprintDates" Margin="6,0,0,0" Foreground="Gray">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="({0:dd/MM/yy} – {1:dd/MM/yy})">
                                                    <Binding Path="Start"/>
                                                    <Binding Path="End"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <!-- Opção "(sem sprint)": Path nulo, sem datas -->
                                        <DataTrigger Binding="{Binding Path}" Value="{x:Null}">
                                            <Setter TargetName="SprintDates" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

        </DataGrid.Columns>

    </DataGrid>

    </Grid>
</UserControl>
