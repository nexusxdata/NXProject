<UserControl x:Class="NXProject.Controls.TaskGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NXProject.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DataGrid x:Name="TaskGrid"
              ItemsSource="{Binding Tasks, RelativeSource={RelativeSource AncestorType=UserControl}}"
              SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
              AutoGenerateColumns="False"
              AllowDrop="True"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              ScrollViewer.CanContentScroll="False"
              SelectionUnit="FullRow"
              Background="White"
              BorderThickness="0"
              RowHeight="22"
              ColumnHeaderHeight="40"
              PreviewMouseLeftButtonDown="OnTaskGridPreviewMouseLeftButtonDown"
              PreviewMouseMove="OnTaskGridPreviewMouseMove"
              DragOver="OnTaskGridDragOver"
              Drop="OnTaskGridDrop">

        <DataGrid.Columns>

            <!-- ID (clicável: abre edição do vínculo DevOps) -->
            <DataGridTemplateColumn x:Name="IdColumn" Header="ID" Width="35" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Button Content="{Binding DisplayId}"
                                Click="OnIdCellClick"
                                ToolTip="Clique para editar o vínculo DevOps (ID, tipo, estado)"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#2B579A"
                                FontSize="11"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Tipo + Estado DevOps (compacto: ex. "FEA·A") -->
            <DataGridTemplateColumn x:Name="DevOpsColumn" Header="T·E" Width="50" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <TextBlock Text="{Binding DevOpsTag}"
                                   Foreground="{Binding DevOpsBrush}"
                                   ToolTip="{Binding DevOpsTooltip}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Nome (com indentação) -->
            <DataGridTemplateColumn x:Name="NameColumn" Header="Nome da Tarefa" Width="*" MinWidth="120">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Indent}"/>
                                <ColumnDefinition Width="14"/><!-- botão expand -->
                                <ColumnDefinition Width="Auto"/><!-- ícone tipo -->
                                <ColumnDefinition Width="*"/><!-- nome -->
                            </Grid.ColumnDefinitions>

                            <!-- Botão expand/collapse — só visível em tarefas-sumário -->
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                          PreviewMouseLeftButtonDown="OnHierarchyTogglePreviewMouseLeftButtonDown"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Width="14" Height="14"
                                          Padding="0" BorderThickness="0"
                                          Background="Transparent"
                                          Cursor="Hand"
                                          Focusable="False">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <TextBlock x:Name="Arrow"
                                                               Text="▶"
                                                               FontSize="9"
                                                               Foreground="#2B579A"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <!-- Ícone: milestone ou summary -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,3,0"
                                       FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayAsMilestone}" Value="True">
                                                <Setter Property="Text" Value="♦"/>
                                                <Setter Property="Foreground" Value="Goldenrod"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Nome (+ selo BLOCK quando bloqueado) -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Margin="0,0,5,0" Padding="4,0" CornerRadius="3"
                                        Background="#FDE7E9" BorderBrush="#D13438" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⛔ BLOCK" FontSize="9" FontWeight="SemiBold"
                                               Foreground="#A4262C" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Indent}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- Duração -->
            <DataGridTemplateColumn x:Name="DurationColumn" Header="Dur.(d)" Width="55">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Border Padding="2,0"
                                CornerRadius="2"
                                Background="Transparent">
                            <TextBlock Text="{Binding DurationDays}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UsesSfpEstimate}" Value="True">
                                                <Setter Property="Foreground" Value="#6E6E6E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesSfpEstimate}" Value="True">
                                            <Setter Property="Background" Value="#F1F1F1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <TextBox Text="{Binding DurationDays, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="{Binding UsesSfpEstimate}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                    <Setter Property="IsTabStop" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsesSfpEstimate}" Value="True">
                                            <Setter Property="Background" Value="#F1F1F1"/>
                                            <Setter Property="Foreground" Value="#6E6E6E"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                            <Setter Property="IsTabStop" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

            <!-- SFP -->
            <DataGridTextColumn x:Name="SfpColumn" Header="SFP" Binding="{Binding SfpPoints}" Width="55">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Início -->
            <DataGridTextColumn x:Name="StartColumn" Header="Início" Binding="{Binding Start, StringFormat=d}" Width="100">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="3,0"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Fim -->
            <DataGridTextColumn x:Name="FinishColumn" Header="Fim" Binding="{Binding Finish, StringFormat=d}" Width="100">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="3,0"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- % Completo -->
            <DataGridTemplateColumn x:Name="PercentColumn" Header="% Compl." Width="70">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                        <Grid Margin="2,1">
                            <ProgressBar Value="{Binding PercentComplete}" Maximum="100" Height="12"
                                         Background="#E0E0E0" Foreground="#217346"/>
                            <TextBlock Text="{Binding PercentComplete, StringFormat={}{0:0}%}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="9" Foreground="Black"/>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Predecessoras -->
            <DataGridTextColumn x:Name="PredecessorColumn" Header="Pred." Binding="{Binding PredecessorsText}" Width="55">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="3,0"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Recursos -->
            <DataGridTextColumn x:Name="ResourcesColumn" Header="Recursos" Binding="{Binding ResourcesText, Mode=OneWay}" Width="100" IsReadOnly="True">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="3,0"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Sprint -->
            <DataGridTextColumn x:Name="SprintColumn" Header="Sprint" Binding="{Binding SprintNumber}" Width="45" IsReadOnly="True">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

        </DataGrid.Columns>

    </DataGrid>
</UserControl>
