<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cores base -->
    <Color x:Key="PrimaryColor">#2B579A</Color>
    <Color x:Key="AccentColor">#217346</Color>
    <Color x:Key="BackgroundColor">#F0F0F0</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#CCCCCC</Color>
    <Color x:Key="SecondaryTextColor">#666666</Color>
    <Color x:Key="CriticalPathColor">#CC0000</Color>
    <Color x:Key="GanttBarColor">#4472C4</Color>
    <Color x:Key="MilestoneColor">#FFD700</Color>
    <Color x:Key="TodayLineColor">#FF4500</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="CriticalPathBrush" Color="{StaticResource CriticalPathColor}"/>
    <SolidColorBrush x:Key="GanttBarBrush" Color="{StaticResource GanttBarColor}"/>
    <SolidColorBrush x:Key="MilestoneBrush" Color="{StaticResource MilestoneColor}"/>
    <SolidColorBrush x:Key="TodayLineBrush" Color="{StaticResource TodayLineColor}"/>

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolVis"/>

    <!-- Estilo base para botões da toolbar -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Margin" Value="1,0"/>
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0E0E0"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Margin" Value="1,0"/>
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0E0E0"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="#D0E4F7"/>
                <Setter Property="BorderBrush" Value="#2B579A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Estilo do DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowHeight" Value="22"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="SelectionMode" Value="Single"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#E8E8E8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

</ResourceDictionary>
