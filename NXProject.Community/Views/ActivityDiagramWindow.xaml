<Window x:Class="NXProject.Views.ActivityDiagramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagrama de Atividades"
        Width="1200" Height="750"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Diagrama de Atividades" FontSize="16" FontWeight="SemiBold"
                           Foreground="#2B579A" VerticalAlignment="Center" Margin="0,0,24,0"/>

                <TextBlock Text="Expandir níveis:" VerticalAlignment="Center" FontSize="12"
                           Foreground="#555" Margin="0,0,10,0"/>

                <!-- Checkboxes de nível gerados em code-behind -->
                <ItemsControl x:Name="LevelCheckList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsExpanded}"
                                      Margin="0,0,12,0" VerticalAlignment="Center" FontSize="12"
                                      Checked="OnLevelCheckChanged" Unchecked="OnLevelCheckChanged"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="12,0"/>
                <Button Content="↺ Resetar zoom" Height="26" Padding="8,0" Click="OnResetZoom" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Canvas com zoom/pan -->
        <ScrollViewer Grid.Row="1" x:Name="DiagramScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#EBEBEB">
            <Viewbox x:Name="DiagramViewbox" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas x:Name="DiagramCanvas" Background="#EBEBEB"/>
            </Viewbox>
        </ScrollViewer>
    </Grid>
</Window>
