<Window x:Class="NXProject.Community.Views.HierarchyColorPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paleta de Cores — Hierarquia do Cronograma"
        Width="400" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F6FA">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style TargetType="TextBox" x:Key="HexBox">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Checkbox de ativação -->
        <CheckBox x:Name="EnabledCheckBox" Content="Ativar cores por nível de hierarquia"
                  FontSize="13" FontWeight="SemiBold" Foreground="#2B579A"
                  Checked="OnEnabledChanged" Unchecked="OnEnabledChanged"
                  Margin="0,0,0,16"/>

        <!-- Grid de níveis -->
        <Border Background="White" BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="4" Padding="12">
            <Grid x:Name="LevelsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nível" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Cor (hex)" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="" FontWeight="SemiBold" FontSize="11" Foreground="#666"/>

                <!-- Nível 0: Raiz/Projeto -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Nível 0 — Raiz / Projeto" Style="{StaticResource LabelStyle}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="Color0Box" Style="{StaticResource HexBox}" TextChanged="OnColorChanged"/>
                <Border    Grid.Row="2" Grid.Column="2" x:Name="Preview0" Width="24" Height="24" BorderBrush="#AAA" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0"/>

                <!-- Nível 1: Epic -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Nível 1 — Epic" Style="{StaticResource LabelStyle}"/>
                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="Color1Box" Style="{StaticResource HexBox}" TextChanged="OnColorChanged"/>
                <Border    Grid.Row="3" Grid.Column="2" x:Name="Preview1" Width="24" Height="24" BorderBrush="#AAA" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0"/>

                <!-- Nível 2: Feature -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Nível 2 — Feature" Style="{StaticResource LabelStyle}"/>
                <TextBox   Grid.Row="4" Grid.Column="1" x:Name="Color2Box" Style="{StaticResource HexBox}" TextChanged="OnColorChanged"/>
                <Border    Grid.Row="4" Grid.Column="2" x:Name="Preview2" Width="24" Height="24" BorderBrush="#AAA" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0"/>

                <!-- Nível 3: Story -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Nível 3 — Story" Style="{StaticResource LabelStyle}"/>
                <TextBox   Grid.Row="5" Grid.Column="1" x:Name="Color3Box" Style="{StaticResource HexBox}" TextChanged="OnColorChanged"/>
                <Border    Grid.Row="5" Grid.Column="2" x:Name="Preview3" Width="24" Height="24" BorderBrush="#AAA" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0"/>

                <!-- Nível 4+: Task -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Nível 4+ — Task" Style="{StaticResource LabelStyle}"/>
                <TextBox   Grid.Row="6" Grid.Column="1" x:Name="Color4Box" Style="{StaticResource HexBox}" TextChanged="OnColorChanged"/>
                <Border    Grid.Row="6" Grid.Column="2" x:Name="Preview4" Width="24" Height="24" BorderBrush="#AAA" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Botões -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Restaurar Padrão" Width="120" Height="30" Margin="0,0,8,0"
                    Click="OnRestoreDefaults" Background="#F0F4FF" BorderBrush="#AAC" FontSize="12"/>
            <Button Content="Cancelar" Width="80" Height="30" Margin="0,0,8,0"
                    IsCancel="True" FontSize="12"/>
            <Button Content="OK" Width="80" Height="30" IsDefault="True"
                    Click="OnOkClick" Background="#2B579A" Foreground="White"
                    BorderBrush="#1D3F73" FontSize="12"/>
        </StackPanel>
    </StackPanel>
</Window>
