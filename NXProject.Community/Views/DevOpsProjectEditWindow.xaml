<Window x:Class="NXProject.Views.DevOpsProjectEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projeto DevOps"
        Width="420" Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Nome do Projeto" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Height="28" Padding="6,4" Margin="0,0,0,12"/>

            <TextBlock Text="ID DevOps (Work Item Raiz)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="IdBox" Height="28" Padding="6,4" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="90" Height="30" IsDefault="True" Click="OnOkClick"/>
                <Button Content="Cancelar" Width="90" Height="30" Margin="10,0,0,0" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
