<Window x:Class="NXProject.Views.FeaturesHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Help_WindowTitle}"
        Width="980" Height="680"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="#F0F4FA" BorderBrush="#D0DAE8" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,18,16,12">
                    <TextBlock Text="NXProject" FontSize="15" FontWeight="Bold" Foreground="#2B579A"/>
                    <TextBlock Text="{DynamicResource Help_Subtitle}" FontSize="10" Foreground="#667" Margin="0,2,0,0"/>
                </StackPanel>
                <ListBox x:Name="TopicList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="OnTopicChanged"
                         Margin="0,0,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2B579A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D8E4F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Overview}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Schedule}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_ActivityDates}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Gantt}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Predecessors}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Resources}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Sprints}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_DevOps}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_ProjectList}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Sync}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Export}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_HealthCheck}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_AI}"/>
                    <ListBoxItem Content="{DynamicResource Help_Topic_Settings}"/>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#D0DAE8"/>

        <!-- Área de conteúdo -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="28,24,28,20">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
    </Grid>
</Window>
