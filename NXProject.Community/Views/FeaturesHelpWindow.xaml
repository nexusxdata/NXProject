<Window x:Class="NXProject.Views.FeaturesHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guia de Funcionalidades — NXProject Community"
        Width="980" Height="680"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="#F0F4FA" BorderBrush="#D0DAE8" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,18,16,12">
                    <TextBlock Text="NXProject" FontSize="15" FontWeight="Bold" Foreground="#2B579A"/>
                    <TextBlock Text="Guia de Funcionalidades" FontSize="10" Foreground="#667" Margin="0,2,0,0"/>
                </StackPanel>
                <ListBox x:Name="TopicList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="OnTopicChanged"
                         Margin="0,0,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2B579A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D8E4F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="🗂  Visão Geral"/>
                    <ListBoxItem Content="📅  Cronograma"/>
                    <ListBoxItem Content="📆  Datas da Atividade"/>
                    <ListBoxItem Content="📊  Gráfico Gantt"/>
                    <ListBoxItem Content="🔗  Predecessoras"/>
                    <ListBoxItem Content="👥  Recursos"/>
                    <ListBoxItem Content="🏃  Sprints"/>
                    <ListBoxItem Content="☁  Azure DevOps"/>
                    <ListBoxItem Content="📋  Lista de Projetos"/>
                    <ListBoxItem Content="🔄  Sincronização"/>
                    <ListBoxItem Content="📤  Exportação"/>
                    <ListBoxItem Content="❤  Health Check"/>
                    <ListBoxItem Content="🤖  Assistente IA"/>
                    <ListBoxItem Content="⚙  Configurações"/>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#D0DAE8"/>

        <!-- Área de conteúdo -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="28,24,28,20">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
    </Grid>
</Window>
