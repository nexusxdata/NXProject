<Window x:Class="NXProject.Views.CommunityAIWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Assistente IA de Projeto"
        Width="860"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Assistente IA para tarefas de projeto"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#2B579A"/>
                <TextBlock Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#444"
                           Text="Use um token de IA para pedir ajuda na criacao de tarefas, cronograma e distribuicao de atividades. Esta tela vem configurada por padrao para OpenRouter Free. Se houver termos de LGPD, dados pessoais ou conteudo fora do contexto esperado, o sistema apenas avisa que a responsabilidade pelo envio e do usuario e registra a ciencia em log local."/>
                <TextBlock Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#555"
                           Text="O token informado sera gravado somente neste computador e armazenado localmente em formato criptografado para uso desta integracao direta com a API."/>
            </StackPanel>

            <TabControl Grid.Row="1" Margin="0,0,0,14">
                    <TabItem Header="Assistente">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="130"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="140"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Pedido para a IA"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBox x:Name="PromptTextBox"
                                     Grid.Row="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Grid.Row="2"
                                       Text="Retorno da IA"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,14,0,8"/>
                            <TextBox x:Name="SummaryTextBox"
                                     Grid.Row="3"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Grid.Row="4"
                                       Margin="0,14,0,8"
                                       TextWrapping="Wrap"
                                       Foreground="#555"
                                       Text="Revise o retorno textual nesta aba. As atividades em formato tabular ficam na aba 'Tarefas sugeridas'. Ao clicar em 'Aplicar ao projeto', elas serao incluidas no Gantt e esta janela sera fechada."/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Tarefas sugeridas">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Lista tabular de atividades sugeridas"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <DataGrid x:Name="TasksDataGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      BorderBrush="#D9E1EA"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarefa" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Dias" Binding="{Binding DurationDays}" Width="90"/>
                                    <DataGridTextColumn Header="Predecessora" Binding="{Binding PredecessorTaskName}" Width="170"/>
                                    <DataGridTextColumn Header="Responsavel" Binding="{Binding Assignee}" Width="170"/>
                                    <DataGridTextColumn Header="Observacoes" Binding="{Binding Notes}" Width="200"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Configuracao">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#D9E1EA"
                                    BorderThickness="1"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Configuracao da IA"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Text="Token" FontWeight="SemiBold"/>
                                    <PasswordBox x:Name="ApiKeyPasswordBox" Margin="0,6,0,10" Height="30"/>
                                    <TextBlock Margin="0,-2,0,10"
                                               TextWrapping="Wrap"
                                               Foreground="#555">
                                        <Run Text="Para gerar seu token no OpenRouter: "/>
                                        <Hyperlink Click="OnOpenApiKeyGuideClick">abrir guia oficial</Hyperlink>
                                        <Run Text="."/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,10"
                                               TextWrapping="Wrap"
                                               Foreground="#555"
                                               Text="Passos rapidos: entre na plataforma, crie uma API key, copie a chave gerada e cole o token aqui. O endpoint e o modelo padrao ja ficam prontos para teste com OpenRouter Free."/>

                                    <TextBlock Text="Endpoint" FontWeight="SemiBold"/>
                                    <TextBox x:Name="EndpointTextBox" Margin="0,6,0,10" Height="30"/>

                                    <TextBlock Text="Modelo" FontWeight="SemiBold"/>
                                    <TextBox x:Name="ModelTextBox" Margin="0,6,0,10" Height="30"/>

                                    <TextBlock Text="Timeout (segundos)" FontWeight="SemiBold"/>
                                    <TextBox x:Name="TimeoutTextBox" Margin="0,6,0,0" Height="30"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#D9E1EA"
                                    BorderThickness="1"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Contexto e regras"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Text="Contexto atual do projeto"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="ProjectContextTextBox"
                                             Margin="0,6,0,10"
                                             Height="92"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>

                                    <TextBlock Text="Escopo permitido"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#555"
                                               Text="Somente pedidos sobre atividades, tarefas, cronograma, dependencias, estimativas e distribuicao de trabalho por pessoa ou recurso."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,16,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Width="340">
                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#555"
                           Text="Pronto para gerar sugestoes."/>
                <ProgressBar x:Name="RequestProgressBar"
                             Height="14"
                             Margin="0,6,0,0"
                             Minimum="0"
                             Maximum="45"
                             Value="0"
                             Visibility="Collapsed"/>
                <TextBlock x:Name="ProgressTextBlock"
                           Margin="0,4,0,0"
                           Foreground="#666"
                           Visibility="Collapsed"
                           Text="Tempo restante: 45s"/>
            </StackPanel>
            <Button x:Name="GenerateButton"
                    Width="140"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="OnGenerateClick"
                    Content="Gerar sugestoes"/>
            <Button x:Name="ApplyButton"
                    Width="150"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="OnApplyClick"
                    IsEnabled="False"
                    Content="Aplicar ao projeto"/>
            <Button Width="100"
                    Height="34"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="OnCloseClick"
                    Content="Fechar"/>
        </DockPanel>
    </Grid>
</Window>
