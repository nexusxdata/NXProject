<Window x:Class="NXProject.Views.CommunityAboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobre o NXProject Community"
        Width="580"
        Height="410"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <DockPanel Margin="0,0,0,12" LastChildFill="True">
                    <Image x:Name="CompanyLogoImage"
                           Width="150"
                           Height="56"
                           Stretch="Uniform"
                           Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="NXProject Community"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#2B579A"/>

                        <TextBlock x:Name="VersionText"
                                   FontSize="13"
                                   Foreground="#666"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="Edicao comunitaria do NXProject para gerenciamento de tarefas, Gantt e importacao/exportacao."
                           FontSize="13"
                           Foreground="#444"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"/>

                <Border Background="#FFF7E8"
                        BorderBrush="#E8D39A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Como funciona o versionamento"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="O formato usado e versao.release.bugs."
                                   TextWrapping="Wrap"
                                   Foreground="#444"/>
                        <TextBlock Text="Exemplo: 1.0.0 = versao principal 1, release 0 e correcao de bugs 0."
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#444"/>
                    </StackPanel>
                </Border>

                <Border Background="#F5F7FA"
                        BorderBrush="#D9E1EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Empresa"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Nexus XData Tecnologia Ltda"
                                   Margin="0,2,0,10"/>

                        <TextBlock Text="Licenca (Open Core)"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Edicao Community gratuita para pessoas e empresas. Edicao Comercial/Enterprise com suporte e vendida separadamente. Recursos pagos nao fazem parte desta edicao."
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Novas versoes (NXStore)"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Baixe atualizacoes e o pacote Community mais recente em:"
                                   Margin="0,2,0,4"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,0,0,10">
                            <Hyperlink Click="OnNxStoreClick">https://github.com/nexusxdata/NXProject</Hyperlink>
                        </TextBlock>

                        <TextBlock Text="Contato"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="E-mail: comercial.nexus.xdata@gmail.com"
                                   Margin="0,2,0,4"
                                   TextWrapping="Wrap"/>
                        <TextBlock>
                            <Hyperlink Click="OnEmailClick">comercial.nexus.xdata@gmail.com</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Fechar"
                        Width="90"
                        Height="30"
                        IsDefault="True"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
