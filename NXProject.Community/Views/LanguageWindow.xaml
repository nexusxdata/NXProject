<Window x:Class="NXProject.Views.LanguageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Lang_WindowTitle}"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <StackPanel Margin="24,20,24,20" >
        <TextBlock Text="{DynamicResource Lang_Label}"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#1E2A38" Margin="0,0,0,12"/>

        <ComboBox x:Name="LanguageCombo"
                  FontSize="13"
                  Padding="6,4"
                  SelectionChanged="OnLanguageSelectionChanged">
            <ComboBoxItem Tag="pt-BR" Content="🇧🇷  Português (Brasil)"/>
            <ComboBoxItem Tag="en-US" Content="🇺🇸  English (US)"/>
        </ComboBox>

        <Border Background="#FFF7E8" BorderBrush="#F5C842" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,14,0,0">
            <TextBlock Text="{DynamicResource Lang_Note}"
                       FontSize="11" Foreground="#6B4B00"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="OkButton" Content="{DynamicResource Lang_Ok}"
                    Width="80" Height="30" Margin="0,0,8,0"
                    Click="OnOkClick"
                    Background="#2B579A" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0"/>
            <Button x:Name="CancelButton" Content="{DynamicResource Lang_Cancel}"
                    Width="80" Height="30"
                    Click="OnCancelClick"
                    Background="#E5E8ED" Foreground="#333"
                    BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
