<Window x:Class="NXProject.Views.SaveCostConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Salvar configuração de custo"
        Width="480" Height="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Border Padding="24,20">
        <StackPanel>
            <!-- Cabeçalho -->
            <TextBlock Text="💰 Salvar configuração de custo"
                       FontSize="15" FontWeight="SemiBold" Foreground="#2B579A" Margin="0,0,0,4"/>
            <TextBlock Text="O arquivo é criptografado com AES-256-GCM. Guarde a senha — sem ela o arquivo não pode ser aberto."
                       FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <!-- Nome do arquivo -->
            <TextBlock Text="Nome do arquivo" FontSize="11" Foreground="#444" Margin="0,0,0,3"/>
            <TextBox x:Name="FileNameBox" Height="28" Padding="6,4" FontSize="12"
                     Text="recursos-custo.nxcost"/>

            <!-- Pasta destino -->
            <TextBlock Text="Pasta destino" FontSize="11" Foreground="#444" Margin="0,10,0,3"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox" Grid.Column="0" Height="28" Padding="6,4" FontSize="11"
                         IsReadOnly="True" Background="#F5F5F5" Foreground="#333"
                         VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="Alterar..." Height="28" Padding="10,0"
                        FontSize="11" Click="OnChangeFolderClick"/>
            </Grid>

            <!-- Separador visual -->
            <Border Height="1" Background="#E0E0E0" Margin="0,16,0,14"/>

            <!-- Senha -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Senha" FontSize="11" Foreground="#444" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="PasswordBox1" Height="28" Padding="6,4"
                                 PasswordChanged="OnPasswordChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Confirmar senha" FontSize="11" Foreground="#444" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="PasswordBox2" Height="28" Padding="6,4"
                                 PasswordChanged="OnPasswordChanged"/>
                </StackPanel>
            </Grid>
            <TextBlock x:Name="MismatchText" Text="As senhas não conferem."
                       Foreground="#C0392B" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>

            <!-- Botões -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancelar" Width="90" Height="30"
                        FontSize="12" IsCancel="True" Click="OnCancelClick"/>
                <Button x:Name="OkButton" Content="OK" Width="90" Height="30" Margin="8,0,0,0"
                        FontSize="12" FontWeight="SemiBold" IsDefault="True" IsEnabled="False" Click="OnOkClick"
                        Background="#1B5E20" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
