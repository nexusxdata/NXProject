<Window x:Class="NXProject.Views.StoryStatusMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Status do Gráfico"
        Width="640" Height="480"
        MinWidth="500" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Mapeamento de Status TFS → Gráfico"
                   FontSize="16" FontWeight="SemiBold" Foreground="#2B579A"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap" FontSize="11" Foreground="#666"
                   Margin="0,0,0,10">
            Associe cada estado do DevOps a um label de exibição no gráfico.
            Estados com o mesmo label são agrupados em uma única barra.
            Cor em hex RGB (ex.: 4A90D9). Deixe vazio para usar a cor automática.
        </TextBlock>

        <DataGrid x:Name="MappingGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="28" FontSize="12"
                  BorderBrush="#DDD" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Estado TFS (exato)"
                                    Binding="{Binding TfsState, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="160"/>
                <DataGridTextColumn Header="Label no Gráfico"
                                    Binding="{Binding ChartLabel, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="140"/>
                <DataGridTextColumn Header="Cor (hex)"
                                    Binding="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>
                <DataGridTextColumn Header="Ordem"
                                    Binding="{Binding Order, UpdateSourceTrigger=PropertyChanged}"
                                    Width="65"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="+ Adicionar" Width="90" Height="28" Margin="0,0,6,0"
                    Click="OnAddClick"/>
            <Button Content="Remover" Width="80" Height="28" Margin="0,0,6,0"
                    Click="OnRemoveClick"/>
            <Button Content="Pré-definidos" Width="100" Height="28"
                    Click="OnLoadDefaultsClick"
                    ToolTip="Carrega os estados padrão como ponto de partida"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Salvar" Width="80" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="OnSaveClick"/>
            <Button Content="Cancelar" Width="80" Height="28"
                    IsCancel="True" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
