<Window x:Class="NXProject.Views.SprintManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Sprints"
        Width="820" Height="600"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Gerenciar Sprints" FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock Text="Configure as sprints do projeto. Sprints importadas do DevOps têm o caminho preenchido."
                       FontSize="12" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Configurações gerais (inline) -->
        <Border Grid.Row="1" Background="#F5F7FA" BorderBrush="#D9E1EA" BorderThickness="1"
                CornerRadius="6" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Sprint inicial:" VerticalAlignment="Center" FontWeight="SemiBold"
                           FontSize="12" Margin="0,0,8,0"/>
                <TextBox x:Name="FirstSprintBox" Width="52" Height="24" Padding="4,2"
                         VerticalContentAlignment="Center" FontSize="12"/>
                <TextBlock Text="Dias por sprint:" VerticalAlignment="Center" FontWeight="SemiBold"
                           FontSize="12" Margin="20,0,8,0"/>
                <TextBox x:Name="SprintDaysBox" Width="52" Height="24" Padding="4,2"
                         VerticalContentAlignment="Center" FontSize="12"/>
                <TextBlock Text="Numeração:" VerticalAlignment="Center" FontWeight="SemiBold"
                           FontSize="12" Margin="20,0,8,0"/>
                <ComboBox x:Name="NumberingCombo" Width="110" Height="24" FontSize="12"
                          VerticalContentAlignment="Center"/>
                <Button Content="Aplicar" Width="70" Height="24" Margin="16,0,0,0"
                        FontSize="12" Click="OnApplySettingsClick"/>
            </StackPanel>
        </Border>

        <!-- Barra de ferramentas da lista -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="AddSprintButton" Content="+ Incluir Sprint" Width="120" Height="28"
                    Click="OnAddSprintClick"/>
            <Button x:Name="DeleteSprintButton" Content="Excluir Selecionada" Width="140" Height="28"
                    Margin="8,0,0,0" Click="OnDeleteSprintClick"/>
            <TextBlock x:Name="CountLabel" VerticalAlignment="Center" Margin="16,0,0,0"
                       FontSize="12" Foreground="#666"/>
        </StackPanel>

        <!-- Grade de sprints -->
        <DataGrid x:Name="SprintGrid" Grid.Row="4"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="30"
                  FontSize="12"
                  CanUserSortColumns="True">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTfsPath}" Value="True">
                            <Setter Property="Background" Value="#F0F4FF"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Width="45"
                                    Binding="{Binding Number}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Nome" Width="*"
                                    Binding="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"/>

                <DataGridTemplateColumn Header="Início" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StartText}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding Start, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="11" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Fim" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EndText}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding End, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="11" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Duração (dias)" Width="110"
                                    Binding="{Binding DurationDays}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Atividades" Width="90"
                                    Binding="{Binding TaskCount}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Caminho DevOps" Width="200"
                                    Binding="{Binding Path}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#666"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Rodapé -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,16,0"
                       FontSize="12" Foreground="#2E7D32"/>
            <Button Content="Fechar" Width="90" Height="30" IsCancel="True" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
