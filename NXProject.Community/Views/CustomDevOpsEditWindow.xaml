<Window x:Class="NXProject.Views.CustomDevOpsEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom DevOps"
        Width="400" Height="Auto" SizeToContent="Height"
        MinHeight="160" MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">

    <Border Padding="20,16">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Custom DevOps"
                       FontSize="14" FontWeight="SemiBold" Foreground="#333"
                       Margin="0,0,0,4"/>

            <StackPanel x:Name="FieldsPanel"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" IsDefault="True"
                        Click="OnOkClick" FontSize="12"/>
                <Button Content="Cancelar" Width="80" Height="30" Margin="8,0,0,0"
                        IsCancel="True" FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
