<Window x:Class="NXProject.Views.CriticalPathWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caminho Crítico" Width="900" Height="560"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#C0392B" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⬛ Caminho Crítico" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#FFAAAA"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtrar:" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                <TextBox x:Name="FilterBox" Width="200" Height="26" Padding="6,2"
                         TextChanged="OnFilterChanged" FontSize="12"/>
                <Separator Margin="12,0"/>
                <CheckBox x:Name="OnlyCriticalCheck" Content="Só críticas (folga = 0)"
                          IsChecked="True" VerticalAlignment="Center" FontSize="12"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>
                <Separator Margin="12,0"/>
                <TextBlock x:Name="CountText" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <DataGrid Grid.Row="2" x:Name="PathGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  AlternatingRowBackground="#FFF5F5" RowBackground="White"
                  BorderThickness="0" Margin="0"
                  CanUserReorderColumns="False" CanUserResizeRows="False"
                  SelectionMode="Single" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"      Binding="{Binding IdKey}"   Width="80"/>
                <DataGridTextColumn Header="Tipo"    Binding="{Binding TfsType}" Width="70"/>
                <DataGridTextColumn Header="Nome"    Binding="{Binding Name}"    Width="*"/>
                <DataGridTextColumn Header="Início"  Binding="{Binding ESText}"  Width="88"/>
                <DataGridTextColumn Header="Fim"     Binding="{Binding EFText}"  Width="88"/>
                <DataGridTextColumn Header="Duração" Binding="{Binding DurText}" Width="80"/>
                <DataGridTemplateColumn Header="Folga" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FloatText}"
                                       Foreground="{Binding FloatColor}"
                                       FontWeight="{Binding FloatWeight}"
                                       HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Predecessoras" Binding="{Binding PredText}" Width="130"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                            <Setter Property="BorderBrush" Value="#C0392B"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" Width="80" Height="28" IsCancel="True" Click="OnCloseClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
