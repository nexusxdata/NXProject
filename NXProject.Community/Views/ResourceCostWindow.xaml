<Window x:Class="NXProject.Views.ResourceCostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custo por Recurso" Width="1100" Height="620"
        MinWidth="800" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰 Custo por Recurso" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalText" FontSize="12" Foreground="#A5D6A7"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Agrupar por:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <ComboBox x:Name="GroupByCombo" Width="130" Height="26" FontSize="12"
                          SelectionChanged="OnGroupByChanged">
                    <ComboBoxItem Content="Recurso" IsSelected="True"/>
                    <ComboBoxItem Content="Feature"/>
                    <ComboBoxItem Content="Mês"/>
                </ComboBox>
                <Separator Margin="12,0"/>
                <TextBlock Text="Recurso:" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                <ComboBox x:Name="ResourceFilter" Width="160" Height="26" FontSize="12"
                          SelectionChanged="OnFilterChanged"/>
                <Separator Margin="12,0"/>
                <TextBlock Text="Mês:" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                <ComboBox x:Name="MonthFilter" Width="110" Height="26" FontSize="12"
                          SelectionChanged="OnFilterChanged"/>
                <Separator Margin="12,0"/>
                <TextBlock x:Name="CountText" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <DataGrid Grid.Row="2" x:Name="CostGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  AlternatingRowBackground="#F1F8E9" RowBackground="White"
                  BorderThickness="0" FontSize="12"
                  CanUserReorderColumns="False" CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Recurso"  Binding="{Binding ResourceName}" Width="160"/>
                <DataGridTextColumn Header="Tipo"     Binding="{Binding CostTypeLabel}" Width="70"/>
                <DataGridTextColumn Header="Feature"  Binding="{Binding FeatureName}"  Width="*"/>
                <DataGridTextColumn Header="Mês"      Binding="{Binding MonthLabel}"   Width="90"/>
                <DataGridTextColumn Header="HH"       Binding="{Binding HoursText}"    Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Custo (R$)" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CostText}" FontWeight="SemiBold"
                                       HorizontalAlignment="Right" Foreground="#1B5E20"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <Expander IsExpanded="True" Background="#E8F5E9">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="4,0"/>
                                                    <TextBlock Text="{Binding ItemCount, StringFormat='({0} itens)'}"
                                                               Foreground="#555" Margin="8,0" FontSize="11"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
        </DataGrid>

        <!-- Footer totals -->
        <Border Grid.Row="3" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontSize="12" Foreground="#333"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Fechar" Width="80" Height="28" IsCancel="True" Click="OnCloseClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
