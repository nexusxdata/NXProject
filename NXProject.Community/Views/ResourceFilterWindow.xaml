<Window x:Class="NXProject.Views.ResourceFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtrar por Recurso"
        Width="420" Height="520"
        MinWidth="340" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Filtrar por Recurso"
                       FontSize="20" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock Text="Marque os recursos para exibir apenas suas atividades."
                       Margin="0,4,0,0" Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Height="30" Padding="8,4"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchChanged"/>
            <Button Grid.Column="1" Content="Todos" Width="60" Height="30" Margin="6,0,0,0" Click="OnSelectAllClick"/>
            <Button Grid.Column="2" Content="Limpar" Width="60" Height="30" Margin="4,0,0,0" Click="OnClearAllClick"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#D9E1EA" BorderThickness="1" Background="White">
            <ListBox x:Name="ResourceList"
                     ItemsSource="{Binding Rows}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="8,5">
                            <TextBlock Text="{Binding Name}" FontSize="12"/>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <TextBlock x:Name="CountLabel" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#666" FontSize="11"/>
            <Button Content="Cancelar" Width="90" Height="30" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Aplicar" Width="90" Height="30" IsDefault="True" Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
