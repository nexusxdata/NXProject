<Window x:Class="NXProject.Views.StoryStatusChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Status de Stories e Incidentes"
        Width="700" Height="520"
        MinWidth="500" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Status de Stories e Incidentes"
                           FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙ Configurar Status"
                    Height="28" Padding="10,0" VerticalAlignment="Top"
                    Click="OnConfigureClick"/>
        </Grid>

        <Canvas x:Name="ChartCanvas" Grid.Row="1"
                Background="White"
                SizeChanged="OnCanvasSizeChanged"/>

        <TextBlock x:Name="SummaryText" Grid.Row="2"
                   FontSize="12" Foreground="#555" Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
