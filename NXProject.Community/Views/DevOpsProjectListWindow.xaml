<Window x:Class="NXProject.Views.DevOpsProjectListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Portfólio de Projetos"
        Width="580" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="480" MinHeight="360"
        Background="White">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Portfólio de Projetos"
                           FontSize="17" FontWeight="SemiBold" Foreground="#2B579A"/>
                <TextBlock Text="Cadastre os projetos do Azure DevOps para seleção rápida na importação."
                           FontSize="12" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Arquivo da lista -->
            <Border Grid.Row="1" Background="#F5F7FA" BorderBrush="#D9E1EA" BorderThickness="1"
                    CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Arquivo:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock x:Name="FilePathLabel" Grid.Column="1"
                               Text="(nenhum arquivo selecionado)"
                               VerticalAlignment="Center" FontSize="11" Foreground="#555"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    <Button Grid.Column="2" Content="Abrir / Criar..." Width="100" Height="26"
                            Margin="8,0,0,0" Click="OnBrowseFileClick" FontSize="11"/>
                    <Button Grid.Column="3" Content="Salvar Como..." Width="100" Height="26"
                            Margin="6,0,0,0" Click="OnSaveAsClick" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Lista de projetos -->
            <DataGrid x:Name="ProjectsGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderBrush="#D9E1EA"
                      BorderThickness="1"
                      RowBackground="White"
                      AlternatingRowBackground="#F9FAFB"
                      ColumnHeaderHeight="32"
                      RowHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome do Projeto" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" MinWidth="160"/>
                    <DataGridTextColumn Header="ID DevOps (Work Item Raiz)" Binding="{Binding RootWorkItemId, UpdateSourceTrigger=PropertyChanged}"
                                        Width="180"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Botões da lista -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="+ Adicionar" Width="100" Height="28" Click="OnAddClick"/>
                <Button Content="✏ Editar" Width="90" Height="28" Margin="8,0,0,0" Click="OnEditClick"/>
                <Button Content="🗑 Excluir" Width="90" Height="28" Margin="8,0,0,0" Click="OnDeleteClick"/>
            </StackPanel>

            <!-- Botões OK/Cancelar -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="OkButton" Content="OK" Width="100" Height="32"
                        IsDefault="True" Click="OnOkClick"/>
                <Button Content="Cancelar" Width="100" Height="32" Margin="10,0,0,0"
                        IsCancel="True" Click="OnCancelClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
