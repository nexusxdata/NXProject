<Window x:Class="NXProject.Views.PercAlocEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="% de Alocação"
        Width="360"
        Height="340"
        MinWidth="320"
        MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        KeyDown="OnKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- título -->
            <RowDefinition Height="Auto"/>  <!-- nome da tarefa -->
            <RowDefinition Height="Auto"/>  <!-- HH/dia -->
            <RowDefinition Height="Auto"/>  <!-- separador -->
            <RowDefinition Height="Auto"/>  <!-- data fim -->
            <RowDefinition Height="Auto"/>  <!-- separador -->
            <RowDefinition Height="Auto"/>  <!-- % direto -->
            <RowDefinition Height="*"/>     <!-- erro -->
            <RowDefinition Height="Auto"/>  <!-- botões -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="% de Alocação"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#2B579A"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   x:Name="TaskNameText"
                   FontSize="11"
                   Foreground="#555"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,12"/>

        <!-- HH/dia → Calcular -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock Text="Calcular pelo HH/dia:"
                       FontSize="11" Foreground="#777" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="HhDiaBox"
                         Width="60" Height="30" FontSize="13"
                         TextAlignment="Center" Padding="4,4"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="OnPreviewDecimalInput"
                         ToolTip="Horas por dia para calcular o % de alocação"/>
                <TextBlock Text=" h/dia"
                           FontSize="12" Foreground="#444"
                           VerticalAlignment="Center" Margin="2,0,8,0"/>
                <Button Content="Calcular →"
                        Height="30" Padding="10,0" FontSize="12"
                        Click="OnCalculatePercent"
                        ToolTip="Converte HH/dia em % de alocação"/>
            </StackPanel>
        </StackPanel>

        <!-- Separador -->
        <Border Grid.Row="3" Height="1" Background="#DDD" Margin="0,0,0,8"/>

        <!-- Data Fim → Calcular % (engenharia reversa) -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock x:Name="FinishCalcLabel"
                       FontSize="11" Foreground="#777" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="FinishDateBox"
                         Width="100" Height="30" FontSize="13"
                         TextAlignment="Center" Padding="4,4"
                         VerticalContentAlignment="Center"
                         ToolTip="Data fim desejada (dd/MM/aaaa). Calcula o % necessário para concluir até essa data."/>
                <Button Content="Calcular ←"
                        Height="30" Padding="10,0" FontSize="12"
                        Margin="6,0,0,0"
                        Click="OnCalculateFromFinish"
                        ToolTip="Calcula o % de alocação com base na data fim informada"/>
            </StackPanel>
        </StackPanel>

        <!-- Separador -->
        <Border Grid.Row="5" Height="1" Background="#DDD" Margin="0,0,0,8"/>

        <!-- % direto -->
        <StackPanel Grid.Row="6" Orientation="Vertical">
            <TextBlock Text="% de alocação:"
                       FontSize="11" Foreground="#777" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="PercAlocBox"
                         Width="80" Height="32" FontSize="14"
                         TextAlignment="Center" Padding="6,4"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="OnPreviewTextInput"/>
                <TextBlock Text="%"
                           FontSize="14" Foreground="#444"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock x:Name="RangeText"
                           Text="  (1 a 100)"
                           FontSize="11" Foreground="#999"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="7"
                   x:Name="ErrorText"
                   Foreground="#B00020"
                   FontSize="11"
                   Margin="0,6,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Click="OnCancel"/>
            <Button Content="OK"
                    Width="80" Height="30"
                    IsDefault="True"
                    Click="OnOk"
                    Background="#2B579A"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
