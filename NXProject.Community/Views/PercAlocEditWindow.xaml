<Window x:Class="NXProject.Views.PercAlocEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="% de Alocação"
        Width="340"
        Height="200"
        MinWidth="300"
        MinHeight="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        KeyDown="OnKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="% de Alocação"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#2B579A"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   x:Name="TaskNameText"
                   FontSize="11"
                   Foreground="#555"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,14"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBox x:Name="PercAlocBox"
                     Width="80"
                     Height="32"
                     FontSize="14"
                     TextAlignment="Center"
                     Padding="6,4"
                     VerticalContentAlignment="Center"
                     PreviewTextInput="OnPreviewTextInput"/>
            <TextBlock Text="%"
                       FontSize="14"
                       Foreground="#444"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0"/>
            <TextBlock x:Name="RangeText"
                       Text="  (1 a 100)"
                       FontSize="11"
                       Foreground="#999"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   x:Name="ErrorText"
                   Foreground="#B00020"
                   FontSize="11"
                   Margin="0,6,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Click="OnCancel"/>
            <Button Content="OK"
                    Width="80" Height="30"
                    IsDefault="True"
                    Click="OnOk"
                    Background="#2B579A"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
