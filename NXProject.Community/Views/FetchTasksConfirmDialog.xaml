<Window x:Class="NXProject.Views.FetchTasksConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tasks encontradas no DevOps"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="20">
        <TextBlock x:Name="SummaryText" FontSize="13" FontWeight="SemiBold"
                   Margin="0,0,0,4" TextWrapping="Wrap"/>
        <TextBlock x:Name="WarningText" FontSize="11" Foreground="#C00"
                   Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>

        <Button x:Name="BtnInclude" Height="52" Margin="0,0,0,6"
                HorizontalContentAlignment="Left" Padding="12,0"
                Cursor="Hand" Click="OnIncludeClick">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📥" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Incluir no cronograma" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Adiciona as Tasks novas ao cronograma para visualização" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <Button x:Name="BtnRelease" Height="52" Margin="0,0,0,6"
                HorizontalContentAlignment="Left" Padding="12,0"
                Cursor="Hand" Click="OnReleaseClick">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔓" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Liberar atividade (não sincronizar)" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Remove Tasks do cronograma sem sincronizar com DevOps" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <Separator Margin="0,10,0,10"/>

        <Button Content="Cancelar" Height="32" Width="90"
                HorizontalAlignment="Right"
                Click="OnCancelClick"/>
    </StackPanel>
</Window>
