<Window x:Class="NXProject.Views.ProjectPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar Projetos do Portfólio"
        Width="560" Height="520"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Selecionar Projetos do Portfólio"
                   FontSize="16" FontWeight="SemiBold" Foreground="#2B579A"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11" Foreground="#666"
                   Margin="0,0,0,10">
            Marque os projetos a incluir no Mapa de Alocação.
            O tipo OPEX/CAPEX e Centro de Custo são configurados na lista de projetos DevOps.
        </TextBlock>

        <!-- Busca -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     Height="28" Padding="6,0" VerticalContentAlignment="Center" FontSize="12"
                     TextChanged="OnSearchChanged"/>
            <Button Grid.Column="1" Content="Limpar" Width="60" Height="28" Margin="6,0,0,0"
                    Click="OnClearSearchClick"/>
        </Grid>

        <!-- Lista -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <Grid Grid.Row="0" Background="#E8EEF8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Projeto DevOps" FontWeight="SemiBold" FontSize="11"
                               Margin="4,4,0,4" Foreground="#333"/>
                    <TextBlock Grid.Column="2" Text="Tipo" FontWeight="SemiBold" FontSize="11"
                               Margin="4,4,0,4" Foreground="#333"/>
                    <TextBlock Grid.Column="3" Text="Centro de Custo" FontWeight="SemiBold" FontSize="11"
                               Margin="4,4,0,4" Foreground="#333"/>
                    <TextBlock Grid.Column="4" Text="ID raiz" FontWeight="SemiBold" FontSize="11"
                               Margin="4,4,0,4" Foreground="#333"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProjectList" BorderThickness="0" FontSize="12"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Aviso lista vazia -->
        <TextBlock x:Name="EmptyMsg" Grid.Row="3"
                   Text="Nenhum projeto DevOps cadastrado. Configure em Visualizar → Projetos DevOps (lista)."
                   FontSize="12" Foreground="#888" TextWrapping="Wrap"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- Resumo -->
        <TextBlock x:Name="SummaryText" Grid.Row="4"
                   FontSize="11" Foreground="#555" Margin="0,8,0,0"/>

        <!-- OK / Cancelar -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOkClick"/>
            <Button Content="Cancelar" Width="80" Height="28"
                    IsCancel="True" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
