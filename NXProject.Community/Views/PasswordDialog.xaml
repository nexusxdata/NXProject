<Window x:Class="NXProject.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Senha de criptografia"
        Width="380" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="MessageText"
                   TextWrapping="Wrap" Margin="0,0,0,12"
                   FontSize="12" Foreground="#333"/>

        <TextBlock Grid.Row="1" Text="Senha:" FontSize="12" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="2" x:Name="PasswordBox1"
                     Height="28" FontSize="13" Padding="6,2"
                     PasswordChanged="OnPasswordChanged"/>

        <StackPanel Grid.Row="3" x:Name="ConfirmPanel" Visibility="Collapsed" Margin="0,8,0,0">
            <TextBlock Text="Confirmar senha:" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox2" Height="28" FontSize="13" Padding="6,2"
                         PasswordChanged="OnPasswordChanged"/>
            <TextBlock x:Name="MismatchText" Text="As senhas não conferem." Foreground="#C0392B"
                       FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Height="28"
                    IsDefault="True" Click="OnOkClick" IsEnabled="False"/>
            <Button Content="Cancelar" Width="80" Height="28" Margin="8,0,0,0"
                    IsCancel="True" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
