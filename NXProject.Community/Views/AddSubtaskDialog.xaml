<Window x:Class="NXProject.Views.AddSubtaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar Subtarefa"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="20">
        <TextBlock x:Name="SubtitleText"
                   FontSize="12" Foreground="#666"
                   Margin="0,0,0,14"
                   TextWrapping="Wrap"/>

        <Button x:Name="BtnFetch" Height="52" Margin="0,0,0,6"
                HorizontalContentAlignment="Left" Padding="12,0"
                Cursor="Hand" Click="OnFetchClick">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📥" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Buscar Tasks do DevOps" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Baixa as Tasks existentes desta Story no DevOps" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <Button x:Name="BtnTask" Height="52" Margin="0,0,0,6"
                HorizontalContentAlignment="Left" Padding="12,0"
                Cursor="Hand" Click="OnCreateTaskClick">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="➕" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Criar Task (DevOps)" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Nova tarefa vinculada e sincronizável com o DevOps" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <Button x:Name="BtnInternal" Height="52" Margin="0,0,0,6"
                HorizontalContentAlignment="Left" Padding="12,0"
                Cursor="Hand" Click="OnCreateInternalClick">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📌" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Criar Atividade Interna" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Apenas no NXProject, sem vínculo com DevOps" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <Separator Margin="0,10,0,10"/>

        <Button Content="Cancelar" Height="32" Width="90"
                HorizontalAlignment="Right"
                Click="OnCancelClick"/>
    </StackPanel>
</Window>
