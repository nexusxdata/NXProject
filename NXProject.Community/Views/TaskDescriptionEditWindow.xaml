<Window x:Class="NXProject.Views.TaskDescriptionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Descrição"
        Width="620" Height="440"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock Text="A descrição será gravada no DevOps na próxima sincronização."
                       FontSize="10" Foreground="#888" Margin="0,2,0,0"/>
        </StackPanel>

        <TextBox Grid.Row="1"
                 x:Name="DescriptionBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Padding="6"
                 FontFamily="Consolas"
                 FontSize="12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="FetchBtn"
                    Content="⬇ Buscar Descrição Atualizada"
                    Height="28" Padding="10,0"
                    Click="OnFetchFromDevOpsClick"/>
            <TextBlock x:Name="FetchStatus"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="11"
                       Foreground="#666"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Salvar" Width="90" Height="30" IsDefault="True"
                    Click="OnSaveClick"/>
            <Button Content="Cancelar" Width="90" Height="30" IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
