<Window x:Class="NXProject.Views.ClassificationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterar Classificação"
        Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Padding="20,16">
        <StackPanel>
            <TextBlock x:Name="LabelText"
                       Text="Classificação (campo obrigatório na criação no DevOps):"
                       FontSize="12" Foreground="#444" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <ComboBox x:Name="ValueCombo"
                      IsEditable="True"
                      Height="30" FontSize="13"
                      Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Height="30" IsDefault="True"
                        Click="OnOkClick" FontSize="12"/>
                <Button Content="Cancelar" Width="80" Height="30" Margin="8,0,0,0"
                        IsCancel="True" FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
