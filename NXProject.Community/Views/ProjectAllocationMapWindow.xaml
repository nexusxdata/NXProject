<Window x:Class="NXProject.Views.ProjectAllocationMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapa de Alocação para Projetos"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="White">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="Auto"/>  <!-- Controles -->
            <RowDefinition Height="*"/>     <!-- Abas -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="Mapa de Alocação para Projetos"
                   FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"
                   Margin="0,0,0,10"/>

        <!-- Controles -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="☑ Selecionar Projetos"
                    Height="28" Padding="10,0" Margin="0,0,8,0"
                    Click="OnSelectProjectsClick"/>
            <Button x:Name="ImportBtn"
                    Content="☁ Importar do DevOps"
                    Height="28" Padding="10,0" Margin="0,0,16,0"
                    Click="OnImportFromDevOpsClick"/>

            <TextBlock Text="Mês inicial:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
            <ComboBox x:Name="StartMonthBox" Width="110" Height="28" Margin="0,0,8,0" FontSize="12"
                      SelectionChanged="OnPeriodChanged"/>

            <TextBlock Text="Mês final:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
            <ComboBox x:Name="EndMonthBox" Width="110" Height="28" Margin="0,0,12,0" FontSize="12"
                      SelectionChanged="OnPeriodChanged"/>

            <CheckBox x:Name="OnlyWithHoursBox"
                      Content="Ocultar linhas/colunas zeradas"
                      VerticalAlignment="Center" Margin="0,0,12,0"
                      FontSize="12" IsChecked="True"
                      Click="OnFilterChanged"/>

            <CheckBox x:Name="OnlyCurrentHoursBox"
                      Content="Apenas HH atual (alocado)"
                      VerticalAlignment="Center" Margin="0,0,12,0"
                      FontSize="12" IsChecked="False"
                      ToolTip="Marcado: soma só HH Atual (horas já trabalhadas). Desmarcado: soma HH Atual + HH Restante (duração total prevista)."
                      Click="OnFilterChanged"/>

            <Button Content="📊 Exportar Excel" Height="28" Padding="10,0"
                    Click="OnExportExcelClick"/>
        </WrapPanel>

        <!-- Abas -->
        <TabControl Grid.Row="2" x:Name="MainTabControl" SelectionChanged="OnTabChanged">

            <!-- ══ ABA 1: Horas por Projeto ══ -->
            <TabItem Header="Horas por Projeto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>  <!-- Cabeçalho meses -->
                        <RowDefinition Height="20"/>  <!-- Sub-cabeçalho -->
                        <RowDefinition Height="*"/>   <!-- Dados -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>  <!-- Projeto -->
                        <ColumnDefinition Width="160"/>  <!-- Recurso -->
                        <ColumnDefinition Width="80"/>   <!-- Tipo -->
                        <ColumnDefinition Width="120"/>  <!-- CC -->
                        <ColumnDefinition Width="*"/>    <!-- Meses (rola) -->
                    </Grid.ColumnDefinitions>

                    <!-- Cabeçalho linha 1 -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <TextBlock Text="Projeto" Foreground="White" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <TextBlock Text="Recurso" Foreground="White" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <TextBlock Text="Tipo" Foreground="White" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="3" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <TextBlock Text="Centro de Custo" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                   VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
                    </Border>
                    <ScrollViewer x:Name="MonthHeaderScroll" Grid.Row="0" Grid.Column="4"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="MonthHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Cabeçalho linha 2 -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
                    <Border Grid.Row="1" Grid.Column="1" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
                    <Border Grid.Row="1" Grid.Column="2" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
                    <Border Grid.Row="1" Grid.Column="3" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
                    <ScrollViewer x:Name="ResourceHeaderScroll" Grid.Row="1" Grid.Column="4"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ResourceHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Dados -->
                    <ScrollViewer x:Name="LeftScroll" Grid.Row="2" Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ProjectNamePanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <ScrollViewer x:Name="ResScroll" Grid.Row="2" Grid.Column="1"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ProjectResPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <ScrollViewer x:Name="TypeScroll" Grid.Row="2" Grid.Column="2"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ProjectTypePanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <ScrollViewer x:Name="CcScroll" Grid.Row="2" Grid.Column="3"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ProjectCcPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <ScrollViewer x:Name="MainScroll" Grid.Row="2" Grid.Column="4"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ScrollChanged="OnMainScrollChanged">
                        <ItemsControl x:Name="DataRowsPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══ ABA 2: Distribuição por Pessoa ══ -->
            <TabItem Header="Distribuição por Pessoa">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>  <!-- Cabeçalho projetos -->
                        <RowDefinition Height="20"/>  <!-- Sub-cabeçalho (tipo) -->
                        <RowDefinition Height="*"/>   <!-- Dados -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>  <!-- Recurso (fixo) -->
                        <ColumnDefinition Width="*"/>    <!-- Projetos (rola) -->
                    </Grid.ColumnDefinitions>

                    <!-- Cabeçalho fixo -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <TextBlock Text="Recurso / Pessoa" Foreground="White" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>

                    <!-- Cabeçalho de projetos (rola horizontal) -->
                    <ScrollViewer x:Name="DistProjHeaderScroll" Grid.Row="0" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DistProjHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <ScrollViewer x:Name="DistTypeHeaderScroll" Grid.Row="1" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DistTypeHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Coluna Recurso (fixa, rola vertical) -->
                    <ScrollViewer x:Name="DistResScroll" Grid.Row="2" Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DistResPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Dados (rola ambos) -->
                    <ScrollViewer x:Name="DistMainScroll" Grid.Row="2" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ScrollChanged="OnDistScrollChanged">
                        <ItemsControl x:Name="DistDataPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══ ABA 3: Stories por Recurso ══ -->
            <TabItem Header="Stories por Recurso">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>  <!-- Cabeçalho meses (2 linhas) -->
                        <RowDefinition Height="*"/>   <!-- Dados -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="730"/>  <!-- Recurso + Projeto + EPIC + Feature + Story (fixo) -->
                        <ColumnDefinition Width="*"/>    <!-- Meses (rola) -->
                    </Grid.ColumnDefinitions>

                    <!-- Cabeçalho fixo (2 linhas: linha vazia + labels) -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="Recurso" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                           Width="130" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock Text="Projeto" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                           Width="120" VerticalAlignment="Center"/>
                                <TextBlock Text="EPIC" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                           Width="140" VerticalAlignment="Center"/>
                                <TextBlock Text="Feature" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                           Width="140" VerticalAlignment="Center"/>
                                <TextBlock Text="Story / Tarefa" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Cabeçalho de meses (rola horizontal) -->
                    <ScrollViewer x:Name="SrHeaderScroll" Grid.Row="0" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SrHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Coluna fixa (rola vertical) -->
                    <ScrollViewer x:Name="SrLeftScroll" Grid.Row="1" Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                                  ScrollChanged="OnSrLeftScrollChanged">
                        <ItemsControl x:Name="SrLeftPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Dados (rola ambos) -->
                    <ScrollViewer x:Name="SrMainScroll" Grid.Row="1" Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ScrollChanged="OnSrScrollChanged">
                        <ItemsControl x:Name="SrDataPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Rateio">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Header fixo -->
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  x:Name="RateioHeaderScroll">
                        <ItemsControl x:Name="RateioHeaderPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <!-- Dados -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  x:Name="RateioDataScroll">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Coluna fixa: Recurso + Projeto -->
                            <ItemsControl Grid.Column="0" x:Name="RateioLeftPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <!-- Dados por mês -->
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          x:Name="RateioDataScrollInner">
                                <ItemsControl x:Name="RateioDataPanel">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   FontSize="11" Foreground="#555" Margin="0,6,0,0"/>
    </Grid>
</Window>
