<Window x:Class="NXProject.Views.ProjectAllocationMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapa de Alocação para Projetos"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="White">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="Auto"/>  <!-- Controles -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="Mapa de Alocação para Projetos"
                   FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"
                   Margin="0,0,0,10"/>

        <!-- Controles -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="📁 Selecionar Projetos"
                    Height="28" Padding="10,0" Margin="0,0,8,0"
                    Click="OnSelectProjectsClick"/>

            <TextBlock Text="Mês inicial:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
            <ComboBox x:Name="StartMonthBox" Width="110" Height="28" Margin="0,0,8,0" FontSize="12"
                      SelectionChanged="OnPeriodChanged"/>

            <TextBlock Text="Mês final:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
            <ComboBox x:Name="EndMonthBox" Width="110" Height="28" Margin="0,0,12,0" FontSize="12"
                      SelectionChanged="OnPeriodChanged"/>

            <CheckBox x:Name="OnlyWithHoursBox"
                      Content="Ocultar linhas/colunas zeradas"
                      VerticalAlignment="Center" Margin="0,0,12,0"
                      FontSize="12" IsChecked="True"
                      Click="OnFilterChanged"/>

            <Button Content="Atualizar" Height="28" Padding="10,0" Margin="0,0,8,0"
                    Click="OnRefreshClick"/>
            <Button Content="Salvar configuração" Height="28" Padding="10,0"
                    Click="OnSaveConfigClick"/>
        </WrapPanel>

        <!-- Grid principal: colunas fixas à esquerda + área rolável à direita -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>  <!-- Cabeçalho meses -->
                <RowDefinition Height="20"/>  <!-- Sub-cabeçalho -->
                <RowDefinition Height="*"/>   <!-- Dados -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>  <!-- Projeto -->
                <ColumnDefinition Width="160"/>  <!-- Recurso -->
                <ColumnDefinition Width="80"/>   <!-- Tipo -->
                <ColumnDefinition Width="120"/>  <!-- CC -->
                <ColumnDefinition Width="*"/>    <!-- Meses (rola) -->
            </Grid.ColumnDefinitions>

            <!-- ═══ CABEÇALHO LINHA 1: meses ═══ -->
            <Border Grid.Row="0" Grid.Column="0" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                <TextBlock Text="Projeto" Foreground="White" FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                <TextBlock Text="Recurso" Foreground="White" FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                <TextBlock Text="Tipo" Foreground="White" FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="3" Background="#2B579A" BorderBrush="#1D3F73" BorderThickness="0,0,1,1">
                <TextBlock Text="Centro de Custo" Foreground="White" FontWeight="SemiBold" FontSize="11"
                           VerticalAlignment="Center" Margin="4,0,0,0" TextWrapping="Wrap"/>
            </Border>
            <!-- Cabeçalho de meses (rola horizontalmente) -->
            <ScrollViewer x:Name="MonthHeaderScroll" Grid.Row="0" Grid.Column="4"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="MonthHeaderPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- ═══ CABEÇALHO LINHA 2: sub-header ═══ -->
            <Border Grid.Row="1" Grid.Column="0" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
            <Border Grid.Row="1" Grid.Column="1" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
            <Border Grid.Row="1" Grid.Column="2" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
            <Border Grid.Row="1" Grid.Column="3" Background="#E8EEF8" BorderBrush="#C5D0E0" BorderThickness="0,0,1,1"/>
            <ScrollViewer x:Name="ResourceHeaderScroll" Grid.Row="1" Grid.Column="4"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ResourceHeaderPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- ═══ DADOS ═══ -->
            <!-- Coluna Projeto (fixa, rola vertical) -->
            <ScrollViewer x:Name="LeftScroll" Grid.Row="2" Grid.Column="0"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ProjectNamePanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Coluna Recurso (fixa, rola vertical) -->
            <ScrollViewer x:Name="ResScroll" Grid.Row="2" Grid.Column="1"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ProjectResPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Coluna Tipo (fixa, rola vertical) -->
            <ScrollViewer x:Name="TypeScroll" Grid.Row="2" Grid.Column="2"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ProjectTypePanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Coluna CC (fixa, rola vertical) -->
            <ScrollViewer x:Name="CcScroll" Grid.Row="2" Grid.Column="3"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ProjectCcPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Área de horas (rola em ambas as direções) -->
            <ScrollViewer x:Name="MainScroll" Grid.Row="2" Grid.Column="4"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="OnMainScrollChanged">
                <ItemsControl x:Name="DataRowsPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <TextBlock x:Name="StatusText" Grid.Row="3"
                   FontSize="11" Foreground="#555" Margin="0,6,0,0"/>
    </Grid>
</Window>
