<Window x:Class="NXProject.Views.PercentCompleteFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtrar por % concluido"
        Width="380" Height="270"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Filtrar por % concluido"
                       FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock Text="Informe uma faixa entre 0 e 100. Campos vazios deixam a ponta aberta."
                       Margin="0,4,0,0" Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Minimo" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="MinBox"
                         Height="30"
                         Padding="8,4"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Maximo" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="MaxBox"
                         Height="30"
                         Padding="8,4"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="ErrorText"
                   Foreground="#B00020"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <CheckBox Grid.Row="3"
                  x:Name="ActiveOnlyCheck"
                  Content="Somente ativas (abaixo de 100%)"
                  Margin="0,8,0,0"
                  VerticalAlignment="Top"
                  Checked="OnActiveOnlyChanged"
                  Unchecked="OnActiveOnlyChanged"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Limpar" Width="80" Height="30" Margin="0,0,8,0" Click="OnClearClick"/>
            <Button Content="Cancelar" Width="90" Height="30" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Aplicar" Width="90" Height="30" IsDefault="True" Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
