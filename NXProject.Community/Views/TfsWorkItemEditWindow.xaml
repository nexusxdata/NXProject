<Window x:Class="NXProject.Views.TfsWorkItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vínculo DevOps"
        Width="520"
        Height="Auto"
        SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Vínculo com o TFS / Azure DevOps"
                               FontSize="16" FontWeight="SemiBold" Foreground="#2B579A"/>
                    <Button x:Name="LoadOnlineTasksButton"
                            Grid.Column="1"
                            Content="Ler Tasks online"
                            Padding="8,3" FontSize="11"
                            Margin="0,0,6,0"
                            Visibility="Collapsed"
                            Click="OnLoadOnlineTasksClick"
                            Cursor="Hand"/>
                    <Button x:Name="OpenInDevOpsButton"
                            Grid.Column="2"
                            Content="Abrir no DevOps ↗"
                            Padding="8,3" FontSize="11"
                            Visibility="Collapsed"
                            Click="OnOpenInDevOpsClick"
                            Cursor="Hand"/>
                </Grid>
                <TextBlock x:Name="TaskNameText" Foreground="#666" FontSize="12"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="ID do DevOps" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="IdBox" Height="28" Padding="6,4"/>
                <TextBlock Text="Digite 0 para criar este item no DevOps ao sincronizar. Vazio = desvincular."
                           FontSize="11" Foreground="#888" Margin="0,3,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="Tipo DevOps" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <ComboBox x:Name="TypeBox" Height="28">
                    <ComboBoxItem>Project</ComboBoxItem>
                    <ComboBoxItem>Epic</ComboBoxItem>
                    <ComboBoxItem>Feature</ComboBoxItem>
                    <ComboBoxItem>Story</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Estado DevOps" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <ComboBox x:Name="StateBox" Height="28">
                    <ComboBoxItem>New</ComboBoxItem>
                    <ComboBoxItem>Active</ComboBoxItem>
                    <ComboBoxItem>Resolved</ComboBoxItem>
                    <ComboBoxItem>Closed</ComboBoxItem>
                    <ComboBoxItem>Removed</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Tags (separadas por ;)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBox x:Name="TagsBox" Height="28" Padding="6,4"/>
                <CheckBox x:Name="BlockCheck" Content="Bloqueado (tag Block)"
                          Margin="0,6,0,0" Checked="OnBlockToggled" Unchecked="OnBlockToggled"/>

                <TextBlock x:Name="StatusText" Foreground="#B00020" TextWrapping="Wrap"
                           Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Atividades filhas (Tasks DevOps) -->
            <Border x:Name="ChildTasksPanel"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    Background="#F5F7FA" BorderBrush="#D9E1EA" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Atividades vinculadas (Tasks DevOps)"
                               FontWeight="SemiBold" FontSize="11" Foreground="#2B579A"
                               Margin="0,0,0,4"/>
                    <ItemsControl x:Name="ChildTasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TfsIdText}"
                                               FontSize="11" Foreground="#2B579A" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding State}"
                                               FontSize="10" Foreground="#666"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="OK" Width="90" Height="30" IsDefault="True" Click="OnOkClick"/>
                <Button Content="Cancelar" Width="90" Height="30" Margin="10,0,0,0" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
