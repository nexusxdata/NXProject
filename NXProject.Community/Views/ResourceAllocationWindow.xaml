<Window x:Class="NXProject.Views.ResourceAllocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade de alocacao"
        Width="980"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Alocacao por recurso e sprint"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F4EA1"/>
                <TextBlock Text="Clique nas horas para ver as atividades e trocar o recurso."
                           Margin="0,3,0,0"
                           Foreground="#555"/>
            </StackPanel>
            <Button Content="Atualizar"
                    Width="92"
                    HorizontalAlignment="Right"
                    Click="OnRefreshClick"/>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="#D0D7E2"
                BorderThickness="1"
                Background="#FAFBFD">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid x:Name="AllocationGrid"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="DetailsTitle"
                       Text="Selecione uma celula da grade"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <DataGrid x:Name="DetailsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      RowHeight="28"
                      ItemsSource="{Binding SelectedDetails, RelativeSource={RelativeSource AncestorType=Window}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Task.DisplayId}"
                                        IsReadOnly="True"
                                        Width="70"/>
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding Task.DevOpsTag}"
                                        IsReadOnly="True"
                                        Width="70"/>
                    <DataGridTextColumn Header="Atividade"
                                        Binding="{Binding Task.Name}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="Horas"
                                        Binding="{Binding Hours, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}"
                                        Width="80"/>
                    <DataGridTemplateColumn Header="Recurso" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableResources, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding Resource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          BorderThickness="0"
                                          Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Fechar"
                    Width="110"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
