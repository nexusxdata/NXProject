<Window x:Class="NXProject.Views.ResourceAllocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade de alocacao"
        Width="1100"
        Height="820"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Alocacao por recurso e sprint"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F4EA1"/>
                <TextBlock Text="Clique nas horas para ver as atividades e trocar o recurso."
                           Margin="0,3,0,0"
                           Foreground="#555"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Incluir"
                        Width="82"
                        Margin="0,0,8,0"
                        Click="OnAddResourceClick"/>
                <Button Content="Excluir"
                        Width="82"
                        Margin="0,0,8,0"
                        Click="OnDeleteResourceClick"/>
                <Button Content="Atualizar"
                        Width="92"
                        Click="OnRefreshClick"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1"
                    x:Name="MainTabControl"
                    SelectionChanged="OnTabChanged">

            <!-- Aba 1: grade de alocação por sprint -->
            <TabItem Header="Alocação">
                <Border BorderBrush="#D0D7E2"
                        BorderThickness="1"
                        Background="#FAFBFD">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="AllocationGrid"/>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- Aba 2: linha do tempo com gaps -->
            <TabItem Header="Gaps / Linha do tempo">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>

                    <!-- Legenda -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="4,6,4,4">
                        <Rectangle Width="16" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="#4A90D9" Margin="0,0,4,0"/>
                        <TextBlock Text="Atividade" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Rectangle Width="16" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="#F5A623" Margin="0,0,4,0"/>
                        <TextBlock Text="Gap (clique para justificar)" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Rectangle Width="16" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="#7B5EA7" Margin="0,0,4,0"/>
                        <TextBlock Text="Gap justificado" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Rectangle Width="2" Height="12"
                                   Fill="#E53935" Margin="0,0,4,0"/>
                        <TextBlock Text="Hoje" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Timeline -->
                    <Border Grid.Row="1"
                            BorderBrush="#D0D7E2"
                            BorderThickness="1"
                            Background="White">
                        <ScrollViewer x:Name="GapScroll"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="GapCanvas"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Splitter visual -->
                    <Border Grid.Row="2" Background="#D0D7E2"/>

                    <!-- Painel de justificativas -->
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Justificativas de gaps  —  clique em uma barra laranja na linha do tempo para adicionar"
                                   FontWeight="SemiBold"
                                   Foreground="#555"
                                   Margin="0,0,0,4"/>

                        <DataGrid Grid.Row="1"
                                  x:Name="GapJustGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  RowHeight="28"
                                  ItemsSource="{Binding GapJustRows, RelativeSource={RelativeSource AncestorType=Window}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Recurso"
                                                    Binding="{Binding ResourceName}"
                                                    IsReadOnly="True"
                                                    Width="160"/>
                                <DataGridTextColumn Header="Início gap"
                                                    Binding="{Binding StartDisplay}"
                                                    IsReadOnly="True"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Fim gap"
                                                    Binding="{Binding EndDisplay}"
                                                    IsReadOnly="True"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Dias úteis"
                                                    Binding="{Binding WorkDays}"
                                                    IsReadOnly="True"
                                                    Width="72"/>
                                <DataGridTextColumn Header="Justificativa"
                                                    Binding="{Binding Justification, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Painel de detalhe (apenas na aba Alocação) -->
        <Grid Grid.Row="2" Margin="0,14,0,0" x:Name="DetailsPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="DetailsTitle"
                       Text="Selecione uma celula da grade"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <DataGrid x:Name="DetailsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      RowHeight="28"
                      ItemsSource="{Binding SelectedDetails, RelativeSource={RelativeSource AncestorType=Window}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Task.DisplayId}"
                                        IsReadOnly="True"
                                        Width="70"/>
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding Task.DevOpsTag}"
                                        IsReadOnly="True"
                                        Width="70"/>
                    <DataGridTextColumn Header="Atividade"
                                        Binding="{Binding Task.Name}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="Início"
                                        Binding="{Binding Task.StartDisplay}"
                                        IsReadOnly="True"
                                        Width="80"/>
                    <DataGridTextColumn Header="Fim"
                                        Binding="{Binding Task.FinishDisplay}"
                                        IsReadOnly="True"
                                        Width="80"/>
                    <DataGridTextColumn Header="Horas"
                                        Binding="{Binding Hours, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}"
                                        Width="80"/>
                    <DataGridTextColumn Header="% Aloc."
                                        Binding="{Binding AllocationPercent, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}"
                                        Width="80"/>
                    <DataGridTemplateColumn Header="Recurso" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableResources, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding Resource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="DisplayName"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          DropDownClosed="OnDetailsResourceComboDropDownClosed"
                                          KeyDown="OnDetailsResourceComboKeyDown"
                                          BorderThickness="0"
                                          Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Fechar"
                    Width="110"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
