<Window x:Class="NXProject.Views.PredecessorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar predecessoras"
        Width="860"
        Height="660"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Predecessoras"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#2B579A"/>
            <TextBlock x:Name="TargetTaskText"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="#444"/>
        </StackPanel>

        <!-- Seção de marcadas: normais + externas separadas -->
        <Border Grid.Row="1"
                Background="#F5F7FA"
                BorderBrush="#D9E1EA"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Marcadas"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="SelectedSummaryText"
                           TextWrapping="Wrap"
                           Foreground="#444"/>

                <!-- Lista de predecessoras externas (fora da lista filtrada) -->
                <ItemsControl x:Name="ExternalPredsList"
                              Margin="0,6,0,0"
                              Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Border Background="#FFF3CD" BorderBrush="#FFEAA0" BorderThickness="1"
                                        CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#856404"/>
                                </Border>
                                <Button Content="✕ Remover"
                                        FontSize="10" Height="20" Padding="4,1"
                                        Background="#FFF3CD" BorderBrush="#FFEAA0"
                                        Tag="{Binding}"
                                        Click="OnRemoveExternalClick"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Height="30"
                     Padding="8,4"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchTextChanged"/>
            <Button Grid.Column="1"
                    Content="Limpar busca"
                    Width="96"
                    Height="30"
                    Margin="8,0,0,0"
                    Click="OnClearSearchClick"/>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="#D9E1EA"
                BorderThickness="1"
                Background="#FFFFFF">
            <ListBox x:Name="CandidateList"
                     ItemsSource="{Binding CandidateRows}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="4,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding DisplayId}"
                                           FontWeight="SemiBold" Foreground="#2B579A" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ParentName}" FontSize="10" Foreground="#888"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Name}" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding StartDate}" FontSize="10"
                                           Foreground="#555" VerticalAlignment="Center" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding FinishDate}" FontSize="10"
                                           Foreground="#555" VerticalAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Button Content="Limpar predecessoras"
                    HorizontalAlignment="Left"
                    Height="30"
                    Padding="12,0"
                    Background="#FFF3F3"
                    BorderBrush="#F5C6C6"
                    Foreground="#C0392B"
                    Click="OnClearPredecessorsClick"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock x:Name="CountText"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Foreground="#666"/>
                <Button Content="Cancelar"
                        Width="96"
                        Height="30"
                        Margin="0,0,8,0"
                        IsCancel="True"/>
                <Button Content="OK"
                        Width="96"
                        Height="30"
                        IsDefault="True"
                        Click="OnOkClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
