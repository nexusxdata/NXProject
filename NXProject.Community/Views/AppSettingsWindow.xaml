<Window x:Class="NXProject.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <StackPanel Margin="24,20,24,20">

        <!-- ══ IDENTIDADE DA EMPRESA ══ -->
        <TextBlock Text="Identidade da empresa" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,12"/>

        <!-- Nome da empresa -->
        <TextBlock Text="Nome da empresa:" FontSize="12" Foreground="#333" Margin="0,0,0,4"/>
        <TextBox x:Name="CompanyNameBox" FontSize="12" Height="28" Padding="6,4"
                 MaxLength="80" Margin="0,0,0,14"
                 Background="White" BorderBrush="#C8CDD5" BorderThickness="1"/>

        <!-- Logo -->
        <TextBlock Text="Logo da empresa (cabeçalho do PDF):" FontSize="12" Foreground="#333" Margin="0,0,0,6"/>

        <!-- Preview box -->
        <Border x:Name="LogoPreviewBorder"
                Width="300" Height="80" HorizontalAlignment="Left"
                Background="White" BorderBrush="#C8CDD5" BorderThickness="1"
                CornerRadius="3" Margin="0,0,0,6">
            <Grid>
                <TextBlock x:Name="LogoPlaceholder"
                           Text="Sem logo — clique em &quot;Escolher imagem&quot;"
                           FontSize="10" Foreground="#AAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="10"/>
                <Image x:Name="LogoPreviewImage" Stretch="Uniform"
                       Margin="6" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="BrowseLogoButton" Content="Escolher imagem..."
                    Height="26" Padding="10,0" Margin="0,0,8,0"
                    Click="OnBrowseLogoClick"
                    Background="#2B579A" Foreground="White" FontSize="11"
                    BorderThickness="0"/>
            <Button x:Name="ClearLogoButton" Content="Remover logo"
                    Height="26" Padding="10,0"
                    Click="OnClearLogoClick"
                    Background="#E5E8ED" Foreground="#555" FontSize="11"
                    BorderThickness="0" IsEnabled="False"/>
        </StackPanel>

        <Border Background="#EEF4FB" BorderBrush="#B8D0EC" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,0,0,20">
            <TextBlock FontSize="10" Foreground="#2B579A" TextWrapping="Wrap">
                <Run FontWeight="SemiBold">Formatos aceitos:</Run>
                <Run>PNG, JPG, BMP, GIF — máx. 5 MB.</Run>
                <LineBreak/>
                <Run FontWeight="SemiBold">Recomendado:</Run>
                <Run>fundo transparente (PNG), proporção 4:1, ex.: 300 × 80 px. A imagem será normalizada automaticamente.</Run>
            </TextBlock>
        </Border>

        <!-- ══ IDIOMA ══ -->
        <TextBlock Text="Idioma / Language" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,12"/>

        <ComboBox x:Name="LanguageCombo" FontSize="12" Height="28" Padding="6,4"
                  Margin="0,0,0,6"
                  SelectionChanged="OnLanguageSelectionChanged">
            <ComboBoxItem Tag="pt-BR" Content="🇧🇷  Português (Brasil)"/>
            <ComboBoxItem Tag="en-US" Content="🇺🇸  English (US)"/>
        </ComboBox>

        <Border Background="#FFF7E8" BorderBrush="#F5C842" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,0,0,24">
            <TextBlock FontSize="10" Foreground="#6B4B00" TextWrapping="Wrap"
                       Text="A alteração é aplicada imediatamente. Menus e toolbar são atualizados em tempo real."/>
        </Border>

        <!-- ══ BOTÕES ══ -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Salvar" Width="90" Height="30" Margin="0,0,8,0"
                    Click="OnSaveClick"
                    Background="#2B579A" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0"/>
            <Button Content="Cancelar" Width="90" Height="30"
                    Click="OnCancelClick"
                    Background="#E5E8ED" Foreground="#333"
                    BorderThickness="0"/>
        </StackPanel>

    </StackPanel>
</Window>
