<Window x:Class="NXProject.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <StackPanel Margin="24,20,24,20">

        <!-- ══ IDENTIDADE DA EMPRESA ══ -->
        <TextBlock Text="{DynamicResource Settings_SectionBranding}" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,12"/>

        <TextBlock Text="{DynamicResource Settings_CompanyName}" FontSize="12" Foreground="#333" Margin="0,0,0,4"/>
        <TextBox x:Name="CompanyNameBox" FontSize="12" Height="28" Padding="6,4"
                 MaxLength="80" Margin="0,0,0,14"
                 Background="White" BorderBrush="#C8CDD5" BorderThickness="1"/>

        <TextBlock Text="{DynamicResource Settings_LogoLabel}" FontSize="12" Foreground="#333" Margin="0,0,0,6"/>

        <Border Width="300" Height="80" HorizontalAlignment="Left"
                Background="White" BorderBrush="#C8CDD5" BorderThickness="1"
                CornerRadius="3" Margin="0,0,0,6">
            <Grid>
                <TextBlock x:Name="LogoPlaceholder"
                           Text="{DynamicResource Settings_LogoPlaceholder}"
                           FontSize="10" Foreground="#AAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="10"/>
                <Image x:Name="LogoPreviewImage" Stretch="Uniform"
                       Margin="6" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="BrowseLogoButton" Content="{DynamicResource Settings_Browse}"
                    Height="26" Padding="10,0" Margin="0,0,8,0"
                    Click="OnBrowseLogoClick"
                    Background="#2B579A" Foreground="White" FontSize="11"
                    BorderThickness="0"/>
            <Button x:Name="ClearLogoButton" Content="{DynamicResource Settings_ClearLogo}"
                    Height="26" Padding="10,0"
                    Click="OnClearLogoClick"
                    Background="#E5E8ED" Foreground="#555" FontSize="11"
                    BorderThickness="0" IsEnabled="False"/>
        </StackPanel>

        <Border Background="#EEF4FB" BorderBrush="#B8D0EC" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,0,0,20">
            <TextBlock FontSize="10" Foreground="#2B579A" TextWrapping="Wrap">
                <Run Text="{DynamicResource Settings_LogoHintFormats}" FontWeight="SemiBold"/>
                <Run Text="{DynamicResource Settings_LogoHintFormatsVal}"/>
                <LineBreak/>
                <Run Text="{DynamicResource Settings_LogoHintSize}" FontWeight="SemiBold"/>
                <Run Text="{DynamicResource Settings_LogoHintSizeVal}"/>
            </TextBlock>
        </Border>

        <!-- ══ IDIOMA ══ -->
        <TextBlock Text="{DynamicResource Settings_SectionLanguage}" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,12"/>

        <ComboBox x:Name="LanguageCombo" FontSize="12" Height="28" Padding="6,4"
                  Margin="0,0,0,6"
                  SelectionChanged="OnLanguageSelectionChanged">
            <ComboBoxItem Tag="pt-BR" Content="🇧🇷  Português (Brasil)"/>
            <ComboBoxItem Tag="en-US" Content="🇺🇸  English (US)"/>
        </ComboBox>

        <Border Background="#FFF7E8" BorderBrush="#F5C842" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,0,0,24">
            <TextBlock Text="{DynamicResource Settings_LangNote}"
                       FontSize="10" Foreground="#6B4B00" TextWrapping="Wrap"/>
        </Border>

        <!-- ══ DIAGNÓSTICO ══ -->
        <TextBlock Text="Diagnóstico" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,8"/>
        <CheckBox x:Name="DebugLogCheck" Content="Habilitar log de diagnóstico"
                  Margin="0,0,0,4" FontSize="12"/>
        <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#666" Margin="20,0,0,4"
                   Text="Grava detalhes de alertas de sprint em %LocalAppData%\NXProject.Community\sprint_alert_debug.log. Ative somente quando solicitado pelo suporte e envie o arquivo gerado."/>
        <Button x:Name="OpenLogBtn" Content="Abrir pasta do log"
                HorizontalAlignment="Left" Height="24" Padding="10,0"
                FontSize="11" Margin="20,0,0,20"
                Click="OnOpenLogFolderClick"/>

        <!-- ══ CATEGORIAS DE TASK (Activity) ══ -->
        <TextBlock Text="Categorias de Task (Activity)" FontSize="13" FontWeight="Bold"
                   Foreground="#2B579A" Margin="0,0,0,6"/>
        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,0,0,6"
                   Text="Lista de opções exibidas na coluna Categoria da Grid de Tasks. Uma categoria por linha. Sincroniza o campo Activity no DevOps."/>
        <TextBox x:Name="ActivityListBox" FontSize="12" Height="120" Padding="6,4"
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Margin="0,0,0,20"
                 FontFamily="Consolas"
                 ToolTip="Uma categoria por linha. Ex: Development, Design, Testing"/>

        <!-- ══ BOTÕES ══ -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Settings_Save}" Width="90" Height="30" Margin="0,0,8,0"
                    Click="OnSaveClick"
                    Background="#2B579A" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0"/>
            <Button Content="{DynamicResource Settings_Cancel}" Width="90" Height="30"
                    Click="OnCancelClick"
                    Background="#E5E8ED" Foreground="#333"
                    BorderThickness="0"/>
        </StackPanel>

    </StackPanel>
</Window>
