<Window x:Class="NXProject.Views.TechLeadTaskReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revisão de Tasks — Tech Lead"
        Width="1160" Height="700"
        MinWidth="900" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="EditCell" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- cabeçalho -->
            <RowDefinition Height="Auto"/>  <!-- breadcrumb seleção -->
            <RowDefinition Height="Auto"/>  <!-- filtros -->
            <RowDefinition Height="*"/>     <!-- grid -->
            <RowDefinition Height="Auto"/>  <!-- totais -->
            <RowDefinition Height="Auto"/>  <!-- botões -->
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Revisão de Tasks — Tech Lead"
                       FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock x:Name="StatusText" FontSize="11" Foreground="#666" Margin="0,2,0,0"
                       Text="Carregando Tasks do DevOps..."/>
        </StackPanel>

        <!-- Breadcrumb da task selecionada: Epic > Feature > Story -->
        <Border Grid.Row="1" Background="#F3F6FC" CornerRadius="4" Padding="10,6"
                Margin="0,0,0,8" Visibility="{Binding ElementName=BreadcrumbPanel, Path=Visibility}">
            <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="📍" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="EpicBreadcrumb"    FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                <TextBlock x:Name="FeatureBreadcrumb" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                <TextBlock x:Name="StoryBreadcrumb"   FontSize="11" FontWeight="SemiBold" Foreground="#2B579A" VerticalAlignment="Center"/>
                <TextBlock Text=" › " FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                <TextBlock x:Name="TaskBreadcrumb"    FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filtros -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8" Orientation="Horizontal">
            <TextBlock Text="Story:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <ComboBox x:Name="StoryFilterBox" Width="200" FontSize="12" Margin="0,0,12,0"
                      SelectionChanged="OnStoryFilterChanged"/>
            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <ComboBox x:Name="StateFilterBox" Width="120" FontSize="12" Margin="0,0,12,0"
                      SelectionChanged="OnStateFilterChanged"/>
            <Button Content="🔄 Recarregar" Click="OnReloadClick"
                    Padding="8,3" FontSize="12" Margin="0,0,8,0"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <TextBlock Text="Duração Story:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <TextBox x:Name="StoryDurationBox" Width="60" FontSize="12" Margin="0,0,4,0"
                     VerticalContentAlignment="Center" ToolTip="Duração total da Story em horas"/>
            <TextBlock Text="h" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
            <Button Content="⚖ Ratear HH nas Tasks" x:Name="RatearButton"
                    Click="OnRatearClick"
                    Padding="8,3" FontSize="12" Margin="0,0,8,0"
                    Background="#7B3F00" Foreground="White"
                    ToolTip="Distribui as horas da Story entre as Tasks com HH Estimado e HH Atual zerados"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
            <Button Content="💾 Salvar alterações no DevOps" x:Name="SaveChangesButton"
                    Click="OnSaveChangesClick"
                    Padding="8,3" FontSize="12" Margin="0,0,8,0"
                    Background="#217346" Foreground="White" IsEnabled="False"/>
        </WrapPanel>

        <!-- Grid de Tasks editável -->
        <DataGrid Grid.Row="3"
                  x:Name="TasksGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="20"
                  SelectionMode="Extended"
                  SelectionChanged="OnTasksGridSelectionChanged"
                  CellEditEnding="OnCellEditEnding"
                  TextElement.FontSize="12"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="OnGridMouseLeftButtonDown"
                  PreviewMouseMove="OnGridMouseMove"
                  Drop="OnGridDrop">
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="⠿" FontSize="11" Foreground="#999" ToolTip="Arraste para reordenar" Cursor="SizeAll"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>
            <DataGrid.Columns>
                <!-- Seleção -->
                <DataGridCheckBoxColumn Header="" Width="28"
                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Numeração sequencial -->
                <DataGridTextColumn Header="#" Width="32"
                    Binding="{Binding RowNumber}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#999"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Hierarquia (somente leitura) -->
                <DataGridTextColumn Header="ID" Width="60"
                    Binding="{Binding TaskId}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2B579A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Story" Width="180"
                    Binding="{Binding StoryName}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Task (editável) -->
                <DataGridTextColumn Header="Task" Width="220"
                    Binding="{Binding Title, UpdateSourceTrigger=LostFocus}"/>

                <!-- Status (editável via template) -->
                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding State}" Padding="2,0"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}" Value="Closed">
                                                <Setter Property="Foreground" Value="#217346"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="Active">
                                                <Setter Property="Foreground" Value="#2B579A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="New">
                                                <Setter Property="Foreground" Value="#888"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox x:Name="StateCombo"
                                      SelectedItem="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                      Loaded="OnStateComboLoaded"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- HH Estimado (editável) -->
                <DataGridTextColumn Header="HH Est." Width="72"
                    Binding="{Binding EstimatedHours, StringFormat={}{0:0.#}, UpdateSourceTrigger=LostFocus}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- HH Concluído (somente leitura) -->
                <DataGridTextColumn Header="HH Conc." Width="72"
                    Binding="{Binding CompletedHours, StringFormat={}{0:0.#}}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                            <Setter Property="Foreground" Value="#666"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Prioridade (editável) -->
                <DataGridTextColumn Header="Pri" Width="45"
                    Binding="{Binding Priority, UpdateSourceTrigger=LostFocus}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#E07000"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Responsável (ComboBox com lista de recursos do projeto) -->
                <DataGridTemplateColumn Header="Responsável" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AssignedToDisplay}" Padding="3,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding ResourceList, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Text="{Binding AssignedToDisplay, UpdateSourceTrigger=LostFocus}"
                                      IsEditable="True"
                                      StaysOpenOnEdit="False"
                                      FontSize="12"
                                      SelectionChanged="OnResourceSelectionChanged"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Categoria / Activity (ComboBox editável sincroniza Microsoft.VSTS.Common.Activity) -->
                <DataGridTemplateColumn Header="Categoria" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Activity}" Padding="2,0" FontSize="12"
                                       Foreground="#444"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Activity, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Loaded="OnActivityComboLoaded"
                                      FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- No cronograma (somente leitura) -->
                <DataGridTextColumn Header="Cronograma" Width="80"
                    Binding="{Binding InScheduleDisplay}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Block -->
                <DataGridTemplateColumn Header="Block" Width="62" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding BlockButtonLabel}"
                                    Click="OnToggleBlockClick"
                                    Padding="4,1" FontSize="10"
                                    Cursor="Hand"
                                    Background="{Binding BlockButtonColor}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    ToolTip="Marcar/retirar Block (altera State para Blocked ou Active)"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu Opened="OnRowContextMenuOpened">
                                <MenuItem x:Name="BlockRowMenuItem"
                                          Header="🔴 Adicionar Block na Task"
                                          Click="OnRowToggleBlockClick"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                            <Setter Property="Background" Value="#FFFDE7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding InSchedule}" Value="True">
                            <Setter Property="Foreground" Value="#888"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Totais e dica de edição -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBlock x:Name="TotalsText" FontSize="11" Foreground="#666"/>
            <TextBlock Text="  |  Células amarelas = alteração pendente de sync DevOps"
                       FontSize="11" Foreground="#B8860B" Margin="8,0,0,0"
                       x:Name="DirtyHint" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Botões rodapé -->
        <DockPanel Grid.Row="5" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="ExpandAllButton" Content="📂 Expandir todas no cronograma"
                        Click="OnExpandAllClick" Height="30" Padding="10,0" Margin="0,0,8,0"
                        Background="#5C3E8F" Foreground="White" Visibility="Collapsed"/>
                <Button x:Name="AddSelectedButton" Content="📥 Incluir selecionadas no cronograma"
                        Click="OnAddSelectedClick" Height="30" Padding="10,0" Margin="0,0,8,0"
                        Background="#2B579A" Foreground="White" IsEnabled="False" Visibility="Collapsed"/>
                <Button x:Name="ReleaseButton" Content="🔓 Liberar atividade"
                        Click="OnReleaseClick" Height="30" Padding="10,0" Margin="0,0,8,0"
                        Background="#C0392B" Foreground="White" Visibility="Collapsed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" Click="OnCloseClick" Width="90" Height="30"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
