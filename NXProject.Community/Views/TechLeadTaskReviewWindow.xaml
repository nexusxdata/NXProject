<Window x:Class="NXProject.Views.TechLeadTaskReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revisão de Tasks — Tech Lead"
        Width="1100" Height="660"
        MinWidth="860" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Revisão de Tasks — Tech Lead"
                       FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
            <TextBlock x:Name="StatusText"
                       FontSize="11" Foreground="#666" Margin="0,3,0,0"
                       Text="Carregando Tasks do DevOps..."/>
        </StackPanel>

        <!-- Filtros -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8" Orientation="Horizontal">
            <TextBlock Text="Filtrar Story:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <ComboBox x:Name="StoryFilterBox" Width="220" FontSize="12" Margin="0,0,12,0"
                      SelectionChanged="OnStoryFilterChanged"/>
            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <ComboBox x:Name="StateFilterBox" Width="130" FontSize="12" Margin="0,0,12,0"
                      SelectionChanged="OnStateFilterChanged"/>
            <Button Content="🔄 Recarregar" Click="OnReloadClick"
                    Padding="8,3" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="📥 Adicionar selecionadas ao cronograma"
                    x:Name="AddSelectedButton"
                    Click="OnAddSelectedClick"
                    Padding="8,3" FontSize="12" IsEnabled="False"
                    Background="#2B579A" Foreground="White"/>
        </WrapPanel>

        <!-- Grid de Tasks -->
        <DataGrid Grid.Row="2"
                  x:Name="TasksGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  SelectionMode="Extended"
                  SelectionChanged="OnTasksGridSelectionChanged"
                  TextElement.FontSize="12">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Width="28" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="ID Task" Width="68" Binding="{Binding TaskId}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Story" Width="160" Binding="{Binding StoryName}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Task" Width="220" Binding="{Binding Title}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Status" Width="100" Binding="{Binding State}" IsReadOnly="True"/>
                <DataGridTextColumn Header="HH Estimado" Width="90" Binding="{Binding EstimatedHoursDisplay}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Prioridade" Width="80" Binding="{Binding Priority}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Responsável" Width="160" Binding="{Binding AssignedTo}" IsReadOnly="True"/>
                <DataGridTextColumn Header="No cronograma" Width="100" Binding="{Binding InScheduleDisplay}" IsReadOnly="True"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding InSchedule}" Value="True">
                            <Setter Property="Foreground" Value="#888"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#E8F0FE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Totais -->
        <TextBlock Grid.Row="3" x:Name="TotalsText"
                   FontSize="11" Foreground="#666" Margin="0,6,0,0"/>

        <!-- Botões -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Fechar" Click="OnCloseClick"
                    Width="90" Height="30" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
