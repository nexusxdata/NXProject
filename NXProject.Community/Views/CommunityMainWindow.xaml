<Window x:Class="NXProject.Views.CommunityMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NXProject.Controls"
        Title="NXProject Community" Height="760" Width="1400" MinHeight="680" MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_File_New}" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="{DynamicResource Menu_File_Clear}" Command="{Binding ClearProjectCommand}"/>
                <MenuItem Header="{DynamicResource Menu_File_Open}" Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Save}" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="{DynamicResource Menu_File_SaveAs}" Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Import}">
                    <MenuItem Header="{DynamicResource Menu_File_Import_OpenProj}" Command="{Binding ImportOpenProjCommand}"/>
                    <MenuItem Header="{DynamicResource Menu_File_Import_MsProject}" Command="{Binding ImportMspdiCommand}"/>
                    <MenuItem Header="{DynamicResource Menu_File_Import_Excel}" Command="{Binding ImportExcelCommand}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_File_Import_Tfs}" Click="OnImportTfsClick"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_File_Export}">
                    <MenuItem Header="{DynamicResource Menu_File_Export_OpenProj}" Command="{Binding ExportOpenProjCommand}"/>
                    <MenuItem Header="{DynamicResource Menu_File_Export_MsProject}" Command="{Binding ExportMspdiCommand}"/>
                    <MenuItem Header="{DynamicResource Menu_File_Export_Excel}" Command="{Binding ExportExcelCommand}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_File_Export_Csv}" Command="{Binding ExportCsvCommand}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_File_Export_SyncTfs}" Click="OnSyncTfsClick"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Exit}" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Edit}">
                <MenuItem Header="{DynamicResource Menu_Edit_AddTask}" Command="{Binding AddTaskCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Edit_AddSubtask}" Command="{Binding AddSubtaskCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Edit_DeleteTask}" Command="{Binding DeleteTaskCommand}"/>
                <MenuItem Header="Abrir no DevOps ↗" Click="OnOpenSelectedTaskInDevOpsClick"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Link}" Command="{Binding LinkTasksSequentiallyCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_MoveUp}"
                          Command="{Binding MoveTaskUpCommand}"
                          CommandParameter="{Binding SelectedTask}"/>
                <MenuItem Header="{DynamicResource Menu_Edit_MoveDown}"
                          Command="{Binding MoveTaskDownCommand}"
                          CommandParameter="{Binding SelectedTask}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Indent}" Command="{Binding IndentTaskCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Edit_Outdent}" Command="{Binding OutdentTaskCommand}"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_View}">
                <MenuItem Header="{DynamicResource Menu_View_Gantt}" Command="{Binding ShowGanttCommand}"/>
                <MenuItem Header="{DynamicResource Menu_View_Sprint}" Click="OnSprintSettingsClick"/>
                <MenuItem Header="{DynamicResource Menu_View_Sfp}" Click="OnSfpSettingsClick"/>
                <MenuItem Header="Customizar colunas..." Click="OnCustomizeColumnsClick"/>
                <MenuItem Header="{DynamicResource Menu_View_Calendar}" Click="OnCalendarSettingsClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_View_DevOpsList}" Click="OnDevOpsProjectListClick"/>
                <MenuItem Header="{DynamicResource Menu_View_People}" Click="OnPeopleClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_View_Language}" Click="OnLanguageClick"/>
                <MenuItem Header="{DynamicResource Menu_View_Settings}" Click="OnAppSettingsClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Manage}">
                <MenuItem Header="{DynamicResource Menu_Manage_Resources}" Click="OnResourceAllocationClick"/>
                <MenuItem Header="{DynamicResource Menu_Manage_HealthCheck}" Click="OnDelayedTasksClick"/>
                <MenuItem Header="{DynamicResource Menu_Manage_StoryStatusChart}" Click="OnStoryStatusChartClick"/>
                <MenuItem Header="{DynamicResource Menu_Manage_AllocationMap}" Click="OnAllocationMapClick"/>
                <MenuItem Header="{DynamicResource Menu_Manage_ActivityDiagram}" Click="OnActivityDiagramClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Manage_Baseline}" SubmenuOpened="OnBaselineMenuOpened">
                    <MenuItem Header="{DynamicResource Menu_Manage_Baseline_Save}"  Click="OnBaselineSaveClick"/>
                    <MenuItem Header="{DynamicResource Menu_Manage_Baseline_Open}"  Click="OnBaselineOpenClick"/>
                    <MenuItem x:Name="BaselineToggleItem"
                              Header="Desativar Baseline"
                              Click="OnBaselineToggleClick"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Manage_Baseline_Clear}" Click="OnBaselineClearClick"/>
                    <Separator/>
                    <MenuItem x:Name="BaselineAutoLoadItem"
                              Header="{DynamicResource Menu_Manage_Baseline_AutoLoad}"
                              IsCheckable="True" IsChecked="True"
                              Click="OnBaselineAutoLoadToggle"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Ai}">
                <MenuItem Header="{DynamicResource Menu_Ai_Assistant}" Click="OnAiAssistantClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Header="{DynamicResource Menu_Help_Features}" Click="OnFeaturesHelpClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Help_Schedule}" Click="OnScheduleUsageHelpClick"/>
                <MenuItem Header="{DynamicResource Menu_Help_AzureDevOps}" Click="OnAzureDevOpsBacklogHelpClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Help_Store}" Click="OnCheckUpdateClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Help_License}" Click="OnLicenseClick"/>
                <MenuItem Header="{DynamicResource Menu_Help_About}" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" Padding="4,2"
                 FocusManager.IsFocusScope="False"
                 Button.Click="OnToolbarButtonClick">
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding NewProjectCommand}" ToolTip="{DynamicResource Toolbar_NewProject}">
                <TextBlock Text="&#x1F4C4;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ClearProjectCommand}" ToolTip="{DynamicResource Toolbar_ClearProject}">
                <TextBlock Text="Limpar" FontSize="11" FontWeight="SemiBold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding OpenProjectCommand}" ToolTip="{DynamicResource Toolbar_Open}">
                <TextBlock Text="&#x1F4C2;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SaveProjectCommand}" ToolTip="{DynamicResource Toolbar_Save}">
                <TextBlock Text="&#x1F4BE;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnOpenSelectedTaskInDevOpsClick" ToolTip="Abrir no DevOps ↗">
                <Viewbox Width="28" Height="16" Stretch="Uniform">
                    <Canvas Width="100" Height="56">
                        <!-- Laço esquerdo -->
                        <Path Stroke="#4A6FA5" StrokeThickness="7" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 50,28 C 50,10 30,2 18,10 C 6,18 6,38 18,46 C 30,54 50,46 50,28"/>
                        <!-- Laço direito -->
                        <Path Stroke="#4A6FA5" StrokeThickness="7" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 50,28 C 50,10 70,2 82,10 C 94,18 94,38 82,46 C 70,54 50,46 50,28"/>
                        <!-- Seta topo esquerdo -->
                        <Polygon Points="22,4 30,8 22,14" Fill="#4A6FA5"/>
                        <!-- Seta baixo direito -->
                        <Polygon Points="78,42 70,46 78,52" Fill="#4A6FA5"/>
                    </Canvas>
                </Viewbox>
            </Button>
            <Separator/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding AddTaskCommand}" ToolTip="{DynamicResource Toolbar_AddTask}">
                <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding AddSubtaskCommand}" ToolTip="{DynamicResource Toolbar_AddSubtask}">
                <TextBlock Text="+&gt;" FontSize="12" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    x:Name="ViewOnlineChildrenBtn"
                    Click="OnViewOnlineChildrenToolbarClick"
                    ToolTip="Ver / Editar Atividades Online da tarefa selecionada">
                <Viewbox Width="22" Height="20" Stretch="Uniform">
                    <Canvas Width="24" Height="24">
                        <!-- linhas de lista -->
                        <Line X1="2" Y1="5"  X2="14" Y2="5"  Stroke="#4A6FA5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="2" Y1="10" X2="14" Y2="10" Stroke="#4A6FA5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="2" Y1="15" X2="10" Y2="15" Stroke="#4A6FA5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <!-- seta externa (canto superior direito) -->
                        <Polyline Points="16,8 22,2 22,7" Stroke="#4A6FA5" StrokeThickness="1.8" Fill="Transparent" StrokeLineJoin="Round"/>
                        <Line X1="17" Y1="2" X2="22" Y2="2" Stroke="#4A6FA5" StrokeThickness="1.8" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding DeleteTaskCommand}" ToolTip="{DynamicResource Toolbar_DeleteTask}">
                <TextBlock Text="&#x1F5D1;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding LinkTasksSequentiallyCommand}" ToolTip="{DynamicResource Toolbar_LinkTasks}">
                <TextBlock Text="&#x26D3;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding IndentTaskCommand}" ToolTip="{DynamicResource Toolbar_Indent}">
                <TextBlock Text="&gt;" FontSize="16" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding OutdentTaskCommand}" ToolTip="{DynamicResource Toolbar_Outdent}">
                <TextBlock Text="&lt;" FontSize="16" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding MoveTaskUpCommand}"
                    CommandParameter="{Binding SelectedTask}"
                    ToolTip="{DynamicResource Toolbar_MoveUp}">
                <TextBlock Text="&#x2191;" FontSize="14" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding MoveTaskDownCommand}"
                    CommandParameter="{Binding SelectedTask}"
                    ToolTip="{DynamicResource Toolbar_MoveDown}">
                <TextBlock Text="&#x2193;" FontSize="14" FontWeight="Bold"/>
            </Button>
            <Separator/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnAiAssistantClick" ToolTip="{DynamicResource Toolbar_Ai}">
                <TextBlock Text="IA" FontSize="12" FontWeight="SemiBold"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnRecalcDatesClick"
                    ToolTip="{DynamicResource Toolbar_RecalcDates}">
                <TextBlock Text="&#x21BB;" FontSize="14"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnRefreshViewClick"
                    ToolTip="{DynamicResource Toolbar_Refresh}">
                <TextBlock Text="&#x1F504;" FontSize="13"/>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnExportPdfClick"
                    ToolTip="{DynamicResource Toolbar_ExportPdf}">
                <Grid Width="30" Height="26">
                    <!-- folha -->
                    <Rectangle RadiusX="2" RadiusY="2"
                               Stroke="#555" StrokeThickness="1.5" Fill="White"
                               Margin="2,0,5,0"/>
                    <!-- dobra superior direita -->
                    <Polyline Points="17,0 23,6 23,6 17,6 17,0"
                              Stroke="#555" StrokeThickness="1.2" Fill="#DDD"/>
                    <!-- letras PDF em vermelho -->
                    <TextBlock Text="PDF" FontSize="8" FontWeight="Bold" Foreground="#CC2200"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,3,3,0"/>
                </Grid>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="OnHierarchyColorPaletteClick"
                    ToolTip="Paleta de cores por nível de hierarquia (Epic / Feature / Story)">
                <Grid Width="22" Height="20">
                    <Rectangle RadiusX="2" RadiusY="2" Fill="#D8D8D8" Margin="0,0,0,10"/>
                    <Rectangle RadiusX="2" RadiusY="2" Fill="#EEEEEE" Margin="0,5,0,5"/>
                    <Rectangle RadiusX="2" RadiusY="2" Fill="#F5F5F5" Margin="0,10,0,0"/>
                </Grid>
            </Button>
            <Separator/>
            <Button x:Name="LayoutToggleButton"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnLayoutToggleClick"
                    ToolTip="{DynamicResource Toolbar_Layout}">
                <TextBlock x:Name="LayoutToggleText" Text="⤢" FontSize="14" FontWeight="SemiBold"/>
            </Button>
            <Separator/>
            <Button x:Name="ResourceFilterButton"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnResourceFilterClick"
                    ToolTip="{DynamicResource Toolbar_ResourceFilter}"
                    MinWidth="36" Padding="4,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F464;" FontSize="13" Margin="0,0,2,0"/>
                    <TextBlock x:Name="ResourceFilterLabel" FontSize="10" VerticalAlignment="Center" Foreground="#2B579A"/>
                </StackPanel>
            </Button>
            <Button x:Name="PercentFilterButton"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnPercentFilterClick"
                    ToolTip="{DynamicResource Toolbar_PercentFilter}"
                    MinWidth="44" Padding="4,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="%" FontSize="12" FontWeight="SemiBold" Margin="0,0,2,0"/>
                    <TextBlock x:Name="PercentFilterLabel" FontSize="10" VerticalAlignment="Center" Foreground="#2B579A"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="ZoomMenuButton"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnZoomMenuClick"
                    ToolTip="{DynamicResource Toolbar_Zoom}"
                    MinWidth="52" Padding="4,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F50D;" FontSize="12" Margin="0,0,3,0"/>
                    <TextBlock x:Name="ZoomLabel" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <ToggleButton x:Name="MagnifierToggle"
                          Style="{StaticResource ToolbarToggleButtonStyle}"
                          Click="OnMagnifierToggleClick"
                          ToolTip="Lupa do Gantt (amplia área sob o cursor)"
                          Padding="6,2">
                <TextBlock Text="&#x1F50E;" FontSize="13"/>
            </ToggleButton>
            <Separator/>
            <Separator/>
            <ToggleButton x:Name="GanttOriginalToggle"
                          ToolTip="Mostrar Gantt pela Estimativa Original"
                          Width="28" Height="24" Padding="3"
                          Checked="OnGanttOriginalToggleChecked"
                          Unchecked="OnGanttOriginalToggleUnchecked"
                          VerticalAlignment="Center">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="18" Height="18">
                        <!-- barra de fundo (estimativa original) -->
                        <Rectangle Canvas.Left="0" Canvas.Top="5" Width="18" Height="8"
                                   Fill="#B91C1C" RadiusX="2" RadiusY="2" Opacity="0.85"/>
                        <!-- linha de referência vertical -->
                        <Line X1="11" Y1="2" X2="11" Y2="16" Stroke="#B91C1C" StrokeThickness="2"/>
                        <!-- barra restante (menor) -->
                        <Rectangle Canvas.Left="0" Canvas.Top="7" Width="11" Height="4"
                                   Fill="#4472C4" RadiusX="1" RadiusY="1"/>
                    </Canvas>
                </Viewbox>
            </ToggleButton>
            <ToggleButton x:Name="DayHeaderToggle"
                          ToolTip="{DynamicResource Toolbar_DayView}"
                          Width="28"
                          Height="24"
                          Padding="3"
                          Checked="OnDayHeaderToggled"
                          Unchecked="OnDayHeaderToggled"
                          VerticalAlignment="Center">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="18" Height="18">
                        <!-- calendário: borda + grade 3x2 -->
                        <Rectangle Canvas.Left="0" Canvas.Top="2" Width="18" Height="16"
                                   Stroke="#444" StrokeThickness="1.5" Fill="Transparent" RadiusX="1" RadiusY="1"/>
                        <!-- linha topo (cabeçalho) -->
                        <Line X1="0" Y1="6" X2="18" Y2="6" Stroke="#444" StrokeThickness="1.2"/>
                        <!-- colunas -->
                        <Line X1="6"  Y1="6" X2="6"  Y2="18" Stroke="#444" StrokeThickness="1"/>
                        <Line X1="12" Y1="6" X2="12" Y2="18" Stroke="#444" StrokeThickness="1"/>
                        <!-- linha meio -->
                        <Line X1="0" Y1="12" X2="18" Y2="12" Stroke="#444" StrokeThickness="1"/>
                        <!-- pinos do topo -->
                        <Line X1="5"  Y1="0" X2="5"  Y2="4" Stroke="#444" StrokeThickness="1.5"/>
                        <Line X1="13" Y1="0" X2="13" Y2="4" Stroke="#444" StrokeThickness="1.5"/>
                    </Canvas>
                </Viewbox>
            </ToggleButton>

            <Separator/>

            <!-- Expandir um nível (todas as do mesmo nível da selecionada) -->
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding ExpandSelectedCommand}"
                    ToolTip="{DynamicResource Toolbar_ExpandSelected}">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="20" Height="18">
                        <!-- linha raiz -->
                        <Line X1="1" Y1="3" X2="10" Y2="3" Stroke="#444" StrokeThickness="1.5"/>
                        <!-- linha do meio (nível expandido) -->
                        <Line X1="4" Y1="10" X2="13" Y2="10" Stroke="#444" StrokeThickness="1.5"/>
                        <!-- conector vertical -->
                        <Line X1="4" Y1="3" X2="4" Y2="10" Stroke="#444" StrokeThickness="1.2"/>
                        <!-- "+1" indicando um nível -->
                        <TextBlock Text="+1" FontSize="7" FontWeight="Bold" Foreground="#2B579A"
                                   Canvas.Left="12" Canvas.Top="0"/>
                        <!-- seta para baixo saindo da raiz -->
                        <Polyline Points="4,10 2,7 6,7" Stroke="#444" StrokeThickness="1.2" Fill="#444"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <Separator/>

            <!-- Contrair toda a hierarquia -->
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding CollapseAllCommand}"
                    ToolTip="{DynamicResource Toolbar_CollapseAll}">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="18" Height="18">
                        <!-- três linhas convergindo para a raiz (colapsar tudo) -->
                        <Line X1="2" Y1="3"  X2="16" Y2="3"  Stroke="#444" StrokeThickness="1.5"/>
                        <Line X1="5" Y1="9"  X2="16" Y2="9"  Stroke="#888" StrokeThickness="1.2"/>
                        <Line X1="8" Y1="15" X2="16" Y2="15" Stroke="#888" StrokeThickness="1.2"/>
                        <!-- setas para cima indicando contração -->
                        <Polyline Points="2,9 5,6 8,9"   Stroke="#444" StrokeThickness="1.2" Fill="Transparent"/>
                        <Polyline Points="2,15 5,12 8,15" Stroke="#444" StrokeThickness="1.2" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- Expandir toda a hierarquia -->
            <Button Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding ExpandAllCommand}"
                    ToolTip="{DynamicResource Toolbar_ExpandAll}">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="18" Height="18">
                        <!-- três linhas divergindo da raiz (expandir tudo) -->
                        <Line X1="2" Y1="3"  X2="16" Y2="3"  Stroke="#444" StrokeThickness="1.5"/>
                        <Line X1="5" Y1="9"  X2="16" Y2="9"  Stroke="#888" StrokeThickness="1.2"/>
                        <Line X1="8" Y1="15" X2="16" Y2="15" Stroke="#888" StrokeThickness="1.2"/>
                        <!-- setas para baixo indicando expansão -->
                        <Polyline Points="2,6 5,9 8,6"   Stroke="#444" StrokeThickness="1.2" Fill="Transparent"/>
                        <Polyline Points="2,12 5,15 8,12" Stroke="#444" StrokeThickness="1.2" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <Separator/>

            <!-- Revisão de Tasks (Tech Lead) -->
            <Button x:Name="TechLeadReviewButton"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="OnTechLeadReviewClick"
                    ToolTip="Revisão de Tasks (Tech Lead) — busca todas as Tasks de todas as Stories no DevOps">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="18" Height="18">
                        <!-- ícone: checklist com lupa -->
                        <Rectangle Canvas.Left="1" Canvas.Top="1" Width="11" Height="16" RadiusX="1" RadiusY="1"
                                   Stroke="#2B579A" StrokeThickness="1.5" Fill="White"/>
                        <Line X1="3.5" Y1="5"  X2="9.5" Y2="5"  Stroke="#2B579A" StrokeThickness="1.2"/>
                        <Line X1="3.5" Y1="8"  X2="9.5" Y2="8"  Stroke="#2B579A" StrokeThickness="1.2"/>
                        <Line X1="3.5" Y1="11" X2="7"   Y2="11" Stroke="#2B579A" StrokeThickness="1.2"/>
                        <!-- lupa -->
                        <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6"
                                 Stroke="#E07000" StrokeThickness="1.5" Fill="Transparent"/>
                        <Line X1="14" Y1="14" X2="17" Y2="17" Stroke="#E07000" StrokeThickness="1.5"/>
                    </Canvas>
                </Viewbox>
            </Button>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PrimaryBrush}" Foreground="White" Height="22">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <Image x:Name="StatusLogoImage"
                       Height="16"
                       Stretch="Uniform"
                       Margin="8,0,0,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Barra de nome do projeto DevOps (visível somente quando há vínculo) -->
        <Border x:Name="DevOpsProjectBanner"
                DockPanel.Dock="Top"
                Background="#EEF4FB" BorderBrush="#B8D0EC" BorderThickness="0,0,0,1"
                Padding="14,4"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔗 Projeto DevOps: " FontSize="12" Foreground="#2B579A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="DevOpsProjectNameLabel" FontSize="12" Foreground="#2B579A" VerticalAlignment="Center"/>
                <TextBlock x:Name="DevOpsProjectIdLabel" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock x:Name="DevOpsEpicHoursLabel" FontSize="11" Foreground="#555" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock x:Name="DevOpsPercentLabel" FontSize="11" Foreground="#2B579A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TaskPaneColumn" Width="660" MinWidth="80"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="GanttPaneColumn" Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ClipToBounds garante que o cronograma é cortado (não espremido) ao arrastar o splitter -->
            <Border Grid.Column="0" ClipToBounds="True">
                <controls:TaskGridControl x:Name="TaskGridCtrl"
                                          DataContext="{Binding}"
                                          Tasks="{Binding FlatTasks}"
                                          AvailableSprints="{Binding SprintOptions}"
                                          AvailableResources="{Binding Project.Resources}"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <controls:GanttControl x:Name="GanttCtrl"
                                   Grid.Column="2"
                                   DataContext="{Binding}"
                                   Tasks="{Binding FlatTasks}"
                                   SelectedTask="{Binding SelectedTask, Mode=TwoWay}"
                                   ProjectStart="{Binding Project.StartDate}"
                                   ZoomLevel="{Binding SelectedZoom}"
                                   FirstSprintNumber="{Binding FirstSprintNumber}"
                                   SprintNumberingMode="{Binding SprintNumberingMode}"
                                   SprintDurationDays="{Binding SprintDurationDays}"
                                   Sprints="{Binding Sprints}"/>
        </Grid>
    </DockPanel>
</Window>
